<UserControl
    x:Class="BlockFactory.Desktop.Views.Reports.ReportsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}">

    <UserControl.Resources>
        <Style x:Key="ReportCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ErpBrushCard}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrintBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="SaveBtn" TargetType="Button"
               BasedOn="{StaticResource PrintBtn}">
            <Setter Property="Background" Value="#2980B9"/>
            <Setter Property="Foreground" Value="{StaticResource ErpBrushCard}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,20">

            <!-- ─── العنوان ─── -->
            <TextBlock Text="📊 التقارير والطباعة"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource ErpBrushNavSidebar}"
                       FontFamily="Segoe UI"
                       Margin="0,0,0,20"/>

            <!-- ─── حالة التحميل ─── -->
            <Border Background="#EBF5FB" CornerRadius="8"
                    Padding="12,8" Margin="0,0,0,16"
                    Visibility="{Binding IsLoading,
                        Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳" FontSize="16"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage,
                                   FallbackValue='جاري المعالجة...'}"
                               FontSize="13" FontFamily="Segoe UI"
                               Foreground="#2980B9"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ─── رسائل الحالة ─── -->
            <Border Background="#FDEDEC" CornerRadius="8"
                    Padding="12,8" Margin="0,0,0,16"
                    Visibility="{Binding HasError,
                        Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E74C3C"
                           FontFamily="Segoe UI" FontSize="13"/>
            </Border>

            <Border Background="#EAFAF1" CornerRadius="8"
                    Padding="12,8" Margin="0,0,0,16"
                    Visibility="{Binding SuccessMessage,
                        Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding SuccessMessage}"
                           Foreground="#27AE60"
                           FontFamily="Segoe UI" FontSize="13"/>
            </Border>

            <!-- ════════════════════════════════════ -->
            <!-- 1. تقرير المبيعات اليومية            -->
            <!-- ════════════════════════════════════ -->
            <Border Style="{StaticResource ReportCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- أيقونة -->
                    <Border Grid.Column="0"
                            Width="56" Height="56"
                            Background="#EBF5FB"
                            CornerRadius="14"
                            Margin="0,0,16,0">
                        <TextBlock Text="💵" FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- المعلومات -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="تقرير المبيعات اليومية"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"
                                   Margin="0,4,0,10">
                            جميع الطلبات والمبيعات ليوم محدد
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="تاريخ التقرير:"
                                       FontSize="12"
                                       FontFamily="Segoe UI"
                                       Foreground="#555"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <DatePicker
                                SelectedDate="{Binding ReportDate}"
                                Height="32" Width="140"
                                FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- أزرار -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                        <Button Style="{StaticResource ErpPrimaryDarkButton}"
                                Content="🖨️ طباعة"
                                MinHeight="38"
                                Padding="16,0"
                                Margin="0,0,8,0"
                                Command="{Binding PrintDailySalesCommand}"/>
                        <Button Style="{StaticResource SaveBtn}"
                                Content="💾 حفظ PDF"
                                Command="{Binding SaveDailySalesCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════ -->
            <!-- 2. تقرير ديون العملاء               -->
            <!-- ════════════════════════════════════ -->
            <Border Style="{StaticResource ReportCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="56" Height="56"
                            Background="#FDEDEC"
                            CornerRadius="14"
                            Margin="0,0,16,0">
                        <TextBlock Text="💳" FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="تقرير ديون العملاء"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#E74C3C"
                                   FontFamily="Segoe UI"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"
                                   Margin="0,4,0,0">
                            قائمة بجميع العملاء الذين لديهم ديون مستحقة
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                        <Button Style="{StaticResource PrintBtn}"
                                Content="🖨️ طباعة"
                                Background="#E74C3C"
                                Foreground="White"
                                Command="{Binding PrintCustomerDebtCommand}"/>
                        <Button Style="{StaticResource SaveBtn}"
                                Content="💾 حفظ PDF"
                                Command="{Binding SaveCustomerDebtCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════ -->
            <!-- 3. تقرير الإنتاج                    -->
            <!-- ════════════════════════════════════ -->
            <Border Style="{StaticResource ReportCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="56" Height="56"
                            Background="#EAFAF1"
                            CornerRadius="14"
                            Margin="0,0,16,0">
                        <TextBlock Text="🏭" FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="تقرير الإنتاج"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#27AE60"
                                   FontFamily="Segoe UI"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"
                                   Margin="0,4,0,10">
                            إجمالي الإنتاج والتالف لفترة محددة
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="من:"
                                       FontSize="12"
                                       FontFamily="Segoe UI"
                                       Foreground="#555"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <DatePicker
                                SelectedDate="{Binding FromDate}"
                                Height="32" Width="130"
                                FontFamily="Segoe UI"
                                Margin="0,0,12,0"/>
                            <TextBlock Text="إلى:"
                                       FontSize="12"
                                       FontFamily="Segoe UI"
                                       Foreground="#555"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <DatePicker
                                SelectedDate="{Binding ToDate}"
                                Height="32" Width="130"
                                FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                        <Button Style="{StaticResource PrintBtn}"
                                Content="🖨️ طباعة"
                                Background="#27AE60"
                                Foreground="White"
                                Command="{Binding PrintProductionCommand}"/>
                        <Button Style="{StaticResource SaveBtn}"
                                Content="💾 حفظ PDF"
                                Command="{Binding SaveProductionCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════ -->
            <!-- 4. تقرير المخزون                    -->
            <!-- ════════════════════════════════════ -->
            <Border Style="{StaticResource ReportCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="56" Height="56"
                            Background="#FEF9E7"
                            CornerRadius="14"
                            Margin="0,0,16,0">
                        <TextBlock Text="📦" FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="تقرير المخزون"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#F39C12"
                                   FontFamily="Segoe UI"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"
                                   Margin="0,4,0,0">
                            كامل مخزون البلوك الجاهز مع الحالة
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                        <Button Style="{StaticResource PrintBtn}"
                                Content="🖨️ طباعة"
                                Background="#F39C12"
                                Foreground="White"
                                Command="{Binding PrintInventoryCommand}"/>
                        <Button Style="{StaticResource SaveBtn}"
                                Content="💾 حفظ PDF"
                                Command="{Binding SaveInventoryCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════ -->
            <!-- 5. كشف رواتب شهري                  -->
            <!-- ════════════════════════════════════ -->
            <Border Style="{StaticResource ReportCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="56" Height="56"
                            Background="#E8F6EF"
                            CornerRadius="14"
                            Margin="0,0,16,0">
                        <TextBlock Text="💰" FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="كشف رواتب شهري"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#27AE60"
                                   FontFamily="Segoe UI"/>
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"
                                   Margin="0,4,0,10">
                            تقرير بجميع العمال والرواتب والسلف والخصومات والصافي
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="الشهر:"
                                       FontSize="12"
                                       FontFamily="Segoe UI"
                                       Foreground="#555"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>
                            <ComboBox
                                ItemsSource="{Binding SalaryMonths}"
                                DisplayMemberPath="Name"
                                SelectedValuePath="Value"
                                SelectedValue="{Binding SalaryReportMonth}"
                                Height="32" Width="130"
                                FontFamily="Segoe UI"
                                Margin="0,0,8,0"/>
                            <ComboBox
                                ItemsSource="{Binding SalaryYears}"
                                SelectedItem="{Binding SalaryReportYear}"
                                Height="32" Width="80"
                                FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                        <Button Style="{StaticResource PrintBtn}"
                                Content="🖨️ طباعة"
                                Background="#27AE60"
                                Foreground="White"
                                Command="{Binding PrintSalarySheetCommand}"/>
                        <Button Style="{StaticResource SaveBtn}"
                                Content="💾 حفظ PDF"
                                Command="{Binding SaveSalarySheetCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
