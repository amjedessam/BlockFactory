<UserControl
    x:Class="BlockFactory.Desktop.Views.HR.SalariesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Totals -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Messages -->
        </Grid.RowDefinitions>

        <!-- ─── Toolbar ─── -->
        <Border Grid.Row="0" Background="{StaticResource ErpBrushCard}"
                CornerRadius="12" Padding="16,12"
                Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.05"
                                  BlurRadius="8" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- اختيار الشهر والسنة -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="📅 الشهر:"
                               FontSize="13" FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Months}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedMonth}"
                              Height="36" Width="130"
                              FontFamily="Segoe UI"
                              FontSize="13"
                              Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding Years}"
                              SelectedItem="{Binding SelectedYear}"
                              Height="36" Width="80"
                              FontFamily="Segoe UI"
                              FontSize="13"
                              Margin="0,0,12,0"/>
                    <Button Content="🔍 عرض"
                            Command="{Binding LoadCommand}"
                            Height="36" Padding="14,0"
                            Background="#2980B9"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"/>
                </StackPanel>

                <!-- اسم الكشف -->
                <TextBlock Grid.Column="1"
                           Text="{Binding SalarySheet.MonthName,
                               FallbackValue='---'}"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource ErpBrushNavSidebar}"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- أزرار -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="💵 صرف"
                            Command="{Binding ShowPayFormCommand}"
                            Visibility="{Binding CanManageSalaries,
                                Converter={StaticResource BoolToVisibility}}"
                            Height="36" Padding="12,0"
                            Margin="0,0,8,0"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"/>

                    <Button Content="🎁 مكافأة"
                            Command="{Binding AddBonusCommand}"
                            Visibility="{Binding CanManageSalaries,
                                Converter={StaticResource BoolToVisibility}}"
                            Height="36" Padding="12,0"
                            Margin="0,0,8,0"
                            Background="#8E44AD"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"/>

                    <Button Content="⚡ إنشاء الكشف"
                            Command="{Binding GenerateCommand}"
                            Visibility="{Binding CanManageSalaries,
                                Converter={StaticResource BoolToVisibility}}"
                            Height="36" Padding="14,0"
                            Background="#E67E22"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            FontWeight="Bold"
                            Cursor="Hand"/>

                    <Button Content="🖨️ طباعة"
                            Command="{Binding PrintSalarySheetCommand}"
                            Height="36" Padding="12,0"
                            Margin="0,0,8,0"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"/>

                    <Button Content="💾 حفظ PDF"
                            Command="{Binding SaveSalarySheetCommand}"
                            Height="36" Padding="12,0"
                            Background="#2980B9"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── إجماليات الكشف ─── -->
        <Border Grid.Row="1"
                Background="{StaticResource ErpBrushNavSidebar}"
                CornerRadius="12"
                Padding="20,14"
                Margin="0,0,0,12"
                Visibility="{Binding SalarySheet,
                    Converter={StaticResource NullToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="إجمالي الرواتب"
                               FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center">
                        <Run Text="{Binding SalarySheet.TotalBasic,
                            StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12"
                             Foreground="#BDC3C7"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="إجمالي السلف"
                               FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="#F39C12"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center">
                        <Run Text="{Binding SalarySheet.TotalAdvances,
                            StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12"
                             Foreground="#BDC3C7"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="الصافي"
                               FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock FontSize="20" FontWeight="Bold"
                               Foreground="#27AE60"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center">
                        <Run Text="{Binding SalarySheet.TotalNet,
                            StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12"
                             Foreground="#BDC3C7"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="المصروف"
                               FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="#27AE60"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center">
                        <Run Text="{Binding SalarySheet.TotalPaid,
                            StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12"
                             Foreground="#BDC3C7"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock Text="المتبقي"
                               FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="#E74C3C"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center">
                        <Run Text="{Binding SalarySheet.TotalRemaining,
                            StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12"
                             Foreground="#BDC3C7"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── محتوى الرواتب ─── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding IsPayFormVisible,
                    Converter={StaticResource BoolToWidth},
                    ConverterParameter='280|0'}"/>
            </Grid.ColumnDefinitions>

            <!-- DataGrid الرواتب -->
            <Border Grid.Column="0" Background="{StaticResource ErpBrushCard}" CornerRadius="12" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <DataGrid
                    ItemsSource="{Binding Salaries}"
                    SelectedItem="{Binding SelectedSalary}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="{StaticResource ErpBrushGridLine}"
                    HeadersVisibility="Column"
                    BorderThickness="0"
                    Background="{StaticResource ErpBrushCard}"
                    RowBackground="{StaticResource ErpBrushCard}"
                    AlternatingRowBackground="{StaticResource ErpBrushRowAlt}"
                    CanUserResizeRows="False"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    RowHeight="44">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="Foreground" Value="{StaticResource ErpBrushTextSecondary}"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="14,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="العامل"
                            Binding="{Binding WorkerName}" Width="*"/>
                        <DataGridTextColumn Header="الراتب"
                            Binding="{Binding BasicSalary,
                                StringFormat='{}{0:N0}'}"
                            Width="100"/>
                        <DataGridTextColumn Header="المكافأة"
                            Binding="{Binding Bonus,
                                StringFormat='{}{0:N0}'}"
                            Width="90"/>
                        <DataGridTextColumn Header="السلف"
                            Binding="{Binding TotalAdvances,
                                StringFormat='{}{0:N0}'}"
                            Width="90"/>
                        <DataGridTextColumn Header="الخصومات"
                            Binding="{Binding TotalDeductions,
                                StringFormat='{}{0:N0}'}"
                            Width="90"/>
                        <DataGridTextColumn Header="الصافي"
                            Binding="{Binding NetSalary,
                                StringFormat='{}{0:N0} ر.ي'}"
                            Width="110"/>
                        <DataGridTextColumn Header="المصروف"
                            Binding="{Binding PaidAmount,
                                StringFormat='{}{0:N0} ر.ي'}"
                            Width="100"/>
                        <DataGridTextColumn Header="المتبقي"
                            Binding="{Binding RemainingAmount,
                                StringFormat='{}{0:N0} ر.ي'}"
                            Width="100"/>

                        <!-- الحالة ملونة -->
                        <DataGridTemplateColumn Header="الحالة" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,3"
                                            HorizontalAlignment="Center"
                                            Margin="4,8">
                                        <Border.Background>
                                            <SolidColorBrush
                                                Color="{Binding StatusColor}"
                                                Opacity="0.15"/>
                                        </Border.Background>
                                        <TextBlock
                                            Text="{Binding Status}"
                                            FontSize="11" FontWeight="SemiBold"
                                            Foreground="{Binding StatusColor}"
                                            HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- ══ نموذج الدفع ══ -->
            <Border Grid.Column="1"
                    Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="20" Margin="0,0,0,0"
                    Visibility="{Binding IsPayFormVisible,
                        Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="💵 صرف راتب"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#27AE60"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,14"/>

                    <!-- بيانات العامل -->
                    <Border Background="#EAFAF1" CornerRadius="8"
                            Padding="10,8" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock
                                Text="{Binding SelectedSalary.WorkerName,
                                    FallbackValue='---'}"
                                FontSize="13" FontWeight="Bold"
                                Foreground="#27AE60"
                                FontFamily="Segoe UI"/>
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"
                                       FontFamily="Segoe UI">
                                <Run Text="المتبقي:"/>
                                <Run Text="{Binding SelectedSalary.RemainingAmount,
                                    FallbackValue='0',
                                    StringFormat='{}{0:N0} ر.ي'}"
                                     Foreground="#E74C3C"
                                     FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- المبلغ -->
                    <TextBlock Text="المبلغ (ر.ي) "
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PayAmount,
                                 UpdateSourceTrigger=PropertyChanged}"
                             Height="38" FontSize="14"
                             FontFamily="Segoe UI"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#27AE60"
                             BorderThickness="2"
                             Margin="0,0,0,12"/>

                    <!-- ملاحظات -->
                    <TextBlock Text="ملاحظات"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PayNotes,
                                 UpdateSourceTrigger=PropertyChanged}"
                             Height="60" TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             FontSize="12" FontFamily="Segoe UI"
                             Padding="8"
                             BorderBrush="{StaticResource ErpBrushBorderInput}"
                             BorderThickness="1.5"
                             Margin="0,0,0,16"/>

                    <!-- رسائل -->
                    <Border Background="#FDEDEC" CornerRadius="8"
                            Padding="10,6" Margin="0,0,0,8"
                            Visibility="{Binding HasError,
                                Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#E74C3C" FontSize="11"
                                   FontFamily="Segoe UI"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Border Background="#EAFAF1" CornerRadius="8"
                            Padding="10,6" Margin="0,0,0,8"
                            Visibility="{Binding SuccessMessage,
                                Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="#27AE60" FontSize="11"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <Button Content="💾 تأكيد الصرف"
                            Command="{Binding SavePayCommand}"
                            Height="40" FontSize="13"
                            FontWeight="Bold"
                            FontFamily="Segoe UI"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,8"/>

                    <Button Content="إلغاء"
                            Command="{Binding CancelPayCommand}"
                            Height="34" FontSize="12"
                            FontFamily="Segoe UI"
                            Background="{StaticResource ErpBrushPageBg}"
                            Foreground="{StaticResource ErpBrushTextSecondary}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource ErpBrushBorderInput}"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- رسائل -->
        <Border Grid.Row="3" Padding="12,8" CornerRadius="8"
                Margin="0,8,0,0"
                Visibility="{Binding HasError,
                    Converter={StaticResource BoolToVisibility}}"
                Background="#FDEDEC">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#E74C3C"
                       FontFamily="Segoe UI" FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
