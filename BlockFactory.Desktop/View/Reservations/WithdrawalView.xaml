<UserControl
    x:Class="BlockFactory.Desktop.Views.Reservations.WithdrawalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ══ النموذج ══ -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,14,0">
            <StackPanel>

                <!-- ─── معلومات الحجز ─── -->
                <Border Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12" Padding="20"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasReservation,
                            Converter={StaticResource BoolToVisibility}}">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.05"
                                          BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text=" معلومات الحجز"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,12"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- رقم الفاتورة -->
                            <Border Grid.Column="0" Background="#EBF5FB"
                                    CornerRadius="8" Padding="12,10"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="رقم الفاتورة"
                                               FontSize="11"
                                               Foreground="{StaticResource ErpBrushTextSecondary}"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock
                                        Text="{Binding Reservation.ReservationNumber}"
                                        FontSize="13" FontWeight="Bold"
                                        FontFamily="Consolas"
                                        Foreground="{StaticResource ErpBrushNavSidebar}"
                                        Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- العميل -->
                            <Border Grid.Column="1" Background="#F8F9FA"
                                    CornerRadius="8" Padding="12,10"
                                    Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="العميل"
                                               FontSize="11"
                                               Foreground="{StaticResource ErpBrushTextSecondary}"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock
                                        Text="{Binding Reservation.CustomerName}"
                                        FontSize="13" FontWeight="Bold"
                                        FontFamily="Segoe UI"
                                        Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- الرصيد المتبقي -->
                            <Border Grid.Column="2" Background="#EAFAF1"
                                    CornerRadius="8" Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="الرصيد المتبقي"
                                               FontSize="11"
                                               Foreground="{StaticResource ErpBrushTextSecondary}"
                                               FontFamily="Segoe UI"/>
                                    <TextBlock FontSize="15" FontWeight="Bold"
                                               Foreground="#27AE60"
                                               FontFamily="Segoe UI"
                                               Margin="0,4,0,0">
                                        <Run Text="{Binding Reservation.AmountRemaining,
                                            StringFormat='{}{0:N0}'}"/>
                                        <Run Text=" ر.ي" FontSize="12"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- نوع الحجز -->
                        <Border Margin="0,10,0,0" Padding="10,8"
                                CornerRadius="6" Background="#F5EEF8"
                                Visibility="{Binding IsOpenBalance,
                                    Converter={StaticResource BoolToVisibility}}">
                            <TextBlock FontSize="12" FontFamily="Segoe UI"
                                       Foreground="#8E44AD">
                                <Run Text="حجز مفتوح —"/>
                                <Run Text="السعر مثبت من تاريخ"/>
                                <Run Text="{Binding Reservation.ReservationDate,
                                    StringFormat='{}{0:dd/MM/yyyy}'}"
                                     FontWeight="Bold"/>
                            </TextBlock>
                        </Border>

                        <Border Margin="0,10,0,0" Padding="10,8"
                                CornerRadius="6" Background="#EBF5FB"
                                Visibility="{Binding IsQuantityReservation,
                                    Converter={StaticResource BoolToVisibility}}">
                            <TextBlock FontSize="12" FontFamily="Segoe UI"
                                       Foreground="#2980B9">
                                <Run Text=" حجز محدد —"/>
                                <Run Text="السحب من الكميات المحجوزة فقط"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ─── إضافة أصناف السحب ─── -->
                <Border Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12" Padding="20"
                        Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.05"
                                          BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📤 تفاصيل السحب"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,14"/>

                        <!-- صف الإضافة -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- المنتج -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="المنتج (بالسعر المثبت)"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555" FontFamily="Segoe UI"
                                           Margin="0,0,0,4"/>
                                <ComboBox
                                    ItemsSource="{Binding AvailableProducts}"
                                    SelectedItem="{Binding SelectedProduct}"
                                    DisplayMemberPath="DisplayText"
                                    Height="38"
                                    FontFamily="Segoe UI" FontSize="13"
                                    Style="{StaticResource ErpFormComboBox}"/>
                            </StackPanel>

                            <!-- الكمية -->
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock
                                    Text="{Binding AvailableQuantityText,
                                        FallbackValue='الكمية'}"
                                    FontSize="11" FontWeight="SemiBold"
                                    Foreground="#555" FontFamily="Segoe UI"
                                    Margin="0,0,0,4"/>
                                <TextBox
                                    Text="{Binding NewItemQuantity,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Height="38" FontFamily="Segoe UI"
                                    Padding="8,0" VerticalContentAlignment="Center"
                                    BorderBrush="{StaticResource ErpBrushBorderInput}"
                                    BorderThickness="1.5"/>
                            </StackPanel>

                            <!-- زر الإضافة -->
                            <Button Grid.Column="2"
                                    Content="➕ إضافة"
                                    Command="{Binding AddItemCommand}"
                                    Height="38" Padding="14,0"
                                    Background="#27AE60" Foreground="White"
                                    BorderThickness="0"
                                    FontFamily="Segoe UI" FontSize="13"
                                    Cursor="Hand"
                                    VerticalAlignment="Bottom"/>
                        </Grid>

                        <!-- السعر المثبت (معلوماتي) -->
                        <Border Background="#FFFDE7" CornerRadius="6"
                                Padding="10,6" Margin="0,8,0,0"
                                Visibility="{Binding SelectedProduct,
                                    Converter={StaticResource NullToVisibility}}">
                            <TextBlock FontSize="12" FontFamily="Segoe UI"
                                       Foreground="#F39C12">
                                <Run Text=" السعر المثبت:"/>
                                <Run Text="{Binding FixedPrice,
                                    Mode=OneWay,
                                    StringFormat='{}{0:N0} ر.ي'}"
                                     FontWeight="Bold"/>
                                <Run Text="— لا يمكن تغييره"/>
                            </TextBlock>
                        </Border>

                        <!-- رسائل الخطأ -->
                        <Border Background="#FDEDEC" CornerRadius="8"
                                Padding="12,8" Margin="0,10,0,0"
                                Visibility="{Binding HasError,
                                    Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#E74C3C" FontSize="12"
                                       FontFamily="Segoe UI" TextWrapping="Wrap"/>
                        </Border>

                        <!-- جدول الأصناف -->
                        <DataGrid
                            ItemsSource="{Binding WithdrawalItems}"
                            AutoGenerateColumns="False"
                            IsReadOnly="False"
                            CanUserAddRows="False"
                            Margin="0,14,0,0"
                            MinHeight="100" RowHeight="42"
                            BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="المنتج"
                                    Binding="{Binding ProductName}"
                                    IsReadOnly="True" Width="*"/>

                                <DataGridTextColumn Header="الكمية"
                                    Binding="{Binding Quantity,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Width="90"/>

                                <DataGridTemplateColumn Header="السعر المثبت"
                                    Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                FontSize="12" FontWeight="SemiBold"
                                                FontFamily="Segoe UI"
                                                Foreground="#8E44AD"
                                                VerticalAlignment="Center"
                                                Margin="8,0">
                                                <Run Text="{Binding FixedPrice,
                                                    Mode=OneWay,
                                                    StringFormat='{}{0:N0}'}"/>
                                                <Run Text=" ر.ي"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="الإجمالي"
                                    Binding="{Binding Total,
                                        StringFormat='{}{0:N0} ر.ي'}"
                                    IsReadOnly="True" Width="110"/>

                                <!-- حذف -->
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑" FontSize="14"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveItemCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ─── التاريخ والملاحظات ─── -->
                <Border Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12" Padding="20"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="تاريخ السحب"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555" FontFamily="Segoe UI"
                                       Margin="0,0,0,5"/>
                            <DatePicker SelectedDate="{Binding WithdrawalDate}"
                                        Height="38" FontFamily="Segoe UI"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="ملاحظات"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#555" FontFamily="Segoe UI"
                                       Margin="0,0,0,5"/>
                            <TextBox Text="{Binding Notes,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     Height="38" FontFamily="Segoe UI"
                                     Padding="10,0" VerticalContentAlignment="Center"
                                     BorderBrush="{StaticResource ErpBrushBorderInput}"
                                     BorderThickness="1.5"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ الملخص والحفظ ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="ملخص السحب"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource ErpBrushNavSidebar}"
                               FontFamily="Segoe UI" Margin="0,0,0,16"/>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="عدد الأصناف:" FontSize="12"
                                   Foreground="#555" FontFamily="Segoe UI"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   FontSize="13" FontWeight="Bold"
                                   FontFamily="Segoe UI"
                                   Text="{Binding WithdrawalItems.Count,
                                       Mode=OneWay}"/>
                    </Grid>

                    <Separator Background="#F0F0F0" Margin="0,10"/>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="إجمالي السحب:"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#E67E22"
                                   FontFamily="Segoe UI">
                            <Run Text="{Binding WithdrawalTotal,
                                StringFormat='{}{0:N0}', Mode=OneWay}"/>
                            <Run Text=" ر.ي" FontSize="12"
                                 Foreground="{StaticResource ErpBrushTextSecondary}"/>
                        </TextBlock>
                    </Grid>

                    <!-- الرصيد بعد السحب -->
                    <Border Background="#F8F9FA" CornerRadius="8"
                            Padding="12,10" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="الرصيد الحالي:"
                                       FontSize="11"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"
                                       FontFamily="Segoe UI"/>
                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="#555" Margin="0,2,0,0">
                                <Run Text="{Binding Reservation.AmountRemaining,
                                    StringFormat='{}{0:N0}', FallbackValue='0'}"/>
                                <Run Text=" ر.ي"/>
                            </TextBlock>
                            <TextBlock Text="الرصيد بعد السحب:"
                                       FontSize="11"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"
                                       FontFamily="Segoe UI"
                                       Margin="0,8,0,0"/>
                            <TextBlock FontSize="15" FontWeight="Bold"
                                       Foreground="#27AE60"
                                       FontFamily="Segoe UI" Margin="0,2,0,0">
                                <!-- حساب تقريبي للعرض -->
                                <Run Text="{Binding Reservation.AmountRemaining,
                                    StringFormat='{}{0:N0}', FallbackValue='—'}"/>
                                <Run Text=" ر.ي" FontSize="11"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- رسالة نجاح -->
                    <Border Background="#EAFAF1" CornerRadius="8"
                            Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding SuccessMessage,
                                Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="#27AE60" FontSize="12"
                                   FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <Button Content="✅ تأكيد السحب"
                        Command="{Binding SaveCommand}"
                        Height="44" FontSize="14" FontWeight="Bold"
                        FontFamily="Segoe UI"
                        Background="#27AE60" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Margin="0,0,0,8"/>

                <Button Content="🗑 مسح"
                        Command="{Binding ClearCommand}"
                        Height="36" FontSize="12" FontFamily="Segoe UI"
                        Background="{StaticResource ErpBrushPageBg}"
                        BorderBrush="{StaticResource ErpBrushBorderInput}"
                        BorderThickness="1" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
