<UserControl
    x:Class="BlockFactory.Desktop.Views.Reservations.NewReservationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ══ النموذج ══ -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,14,0">
            <StackPanel>

                <!-- ─── نوع الحجز ─── -->
                <Border Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12" Padding="20"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="نوع الحجز"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,14"/>

                        <StackPanel Orientation="Horizontal">
                            <!-- حجز محدد -->
                            <Border Margin="0,0,12,0" CornerRadius="10"
                                    Padding="16,12" Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F8F9FA"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsQuantityReservation}"
                                                Value="True">
                                                <Setter Property="Background" Value="#EBF5FB"/>
                                                <Setter Property="BorderBrush" Value="#2980B9"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                        Command="{Binding SelectTypeCommand}"
                                        CommandParameter="Quantity"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <TextBlock Text="📦 حجز محدد"
                                               FontSize="14" FontWeight="Bold"
                                               FontFamily="Segoe UI"
                                               Foreground="#2980B9"/>
                                    <TextBlock Text="تحديد النوع والكمية"
                                               FontSize="11"
                                               Foreground="{StaticResource ErpBrushTextSecondary}"
                                               FontFamily="Segoe UI"
                                               Margin="0,4,0,0"/>
                                    <TextBlock Text="الخصم من الكميات"
                                               FontSize="11"
                                               Foreground="{StaticResource ErpBrushTextSecondary}"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>

                            <!-- حجز مفتوح -->
                            <Border CornerRadius="10" Padding="16,12"
                                    Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#F8F9FA"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding IsOpenBalance}"
                                                Value="True">
                                                <Setter Property="Background" Value="#F5EEF8"/>
                                                <Setter Property="BorderBrush" Value="#8E44AD"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                        Command="{Binding SelectTypeCommand}"
                                        CommandParameter="Open"/>
                                </Border.InputBindings>
                                <StackPanel>
                                    <TextBlock Text="💵 حجز مفتوح"
                                               FontSize="14" FontWeight="Bold"
                                               FontFamily="Segoe UI"
                                               Foreground="#8E44AD"/>
                                    <TextBlock Text="رصيد مالي فقط"
                                               FontSize="11"
                                               Foreground="{StaticResource ErpBrushTextSecondary}"
                                               FontFamily="Segoe UI"
                                               Margin="0,4,0,0"/>
                                    <TextBlock Text="الخصم من الرصيد"
                                               FontSize="11"
                                               Foreground="{StaticResource ErpBrushTextSecondary}"
                                               FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── بيانات العميل ─── -->
                <Border Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12" Padding="20"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text=" بيانات العميل"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="ابحث عن العميل"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" FontFamily="Segoe UI"
                                   Margin="0,0,0,5"/>

                        <!-- حقل البحث + Popup النتائج -->
                        <Grid>
                            <TextBox
                                x:Name="CustomerSearchBox"
                                Height="38"
                                Padding="10,0"
                                FontFamily="Segoe UI"
                                FontSize="13"
                                VerticalContentAlignment="Center"
                                BorderBrush="{StaticResource ErpBrushBorderInput}"
                                BorderThickness="1.5"
                                Text="{Binding CustomerSearch,
                                    UpdateSourceTrigger=PropertyChanged}"/>

                            <!-- نتائج البحث -->
                            <Popup
                                IsOpen="{Binding CustomerResults.Count,
                                    Converter={StaticResource CountToBool},
                                    Mode=OneWay}"
                                PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                                Placement="Bottom"
                                Width="{Binding ActualWidth,
                                    ElementName=CustomerSearchBox}"
                                StaysOpen="False">
                                <Border Background="White"
                                        BorderBrush="#DDE1E7"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000"
                                            Opacity="0.1" BlurRadius="10"
                                            ShadowDepth="3"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <ListBox
                                            x:Name="CustomerListBox"
                                            ItemsSource="{Binding CustomerResults}"
                                            BorderThickness="0"
                                            MaxHeight="200"
                                            FontFamily="Segoe UI"
                                            MouseLeftButtonUp="CustomerListBox_MouseLeftButtonUp">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="10,6">
                                                        <TextBlock
                                                            Text="{Binding FullName}"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Foreground="#2C3E50"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock
                                                                Text="{Binding Phone}"
                                                                FontSize="11"
                                                                Foreground="#7F8C8D"
                                                                Margin="0,0,10,0"/>
                                                            <TextBlock
                                                                FontSize="11"
                                                                Foreground="#E74C3C"
                                                                Visibility="{Binding TotalDebt,
                                                                    Converter={StaticResource DecimalToBool}}">
                                                                <Run Text="دين:"/>
                                                                <Run Text="{Binding TotalDebt,
                                                                    StringFormat='{}{0:N0} ر.ي'}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!-- زر إضافة عميل جديد في نهاية القائمة -->
                                        <Border BorderThickness="0,1,0,0"
                                                BorderBrush="#F0F2F5">
                                            <Button
                                                Command="{Binding ShowQuickAddCommand}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Padding="12,10">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="➕ "
                                                               FontSize="12"
                                                               Foreground="#21416A"/>
                                                    <TextBlock Text="إضافة عميل جديد"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="#21416A"
                                                               FontFamily="Segoe UI"/>
                                                </StackPanel>
                                            </Button>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- زر إضافة عميل جديد مستقل -->
                        <Button
                            Command="{Binding ShowQuickAddCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕ " FontSize="12"
                                           Foreground="#21416A"/>
                                <TextBlock Text="إضافة عميل جديد"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#21416A"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Button>

                        <!-- ── نموذج الإضافة السريعة ── -->
                        <Border
                            Visibility="{Binding IsQuickAddVisible,
                                Converter={StaticResource BoolToVisibility}}"
                            Background="#F0F7FF"
                            BorderBrush="#1A73E8"
                            BorderThickness="1.5"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,10,0,0">
                            <StackPanel>
                                <!-- رأس النموذج -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal">
                                        <TextBlock Text="➕ " FontSize="14"
                                                   Foreground="#21416A"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="إضافة عميل جديد"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#1A2E4A"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Command="{Binding CancelQuickAddCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#7F8C8D"
                                            FontSize="13" Cursor="Hand"
                                            Padding="4"/>
                                </Grid>

                                <!-- حقل الاسم -->
                                <TextBlock Text="الاسم "
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555" FontFamily="Segoe UI"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding QuickAddName,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Height="38" FontFamily="Segoe UI" FontSize="13"
                                         Padding="10,0" VerticalContentAlignment="Center"
                                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                                         BorderThickness="1.5"
                                         Margin="0,0,0,10"/>

                                <!-- حقل الهاتف -->
                                <TextBlock Text="رقم الهاتف"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555" FontFamily="Segoe UI"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding QuickAddPhone,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Height="38" FontFamily="Segoe UI" FontSize="13"
                                         Padding="10,0" VerticalContentAlignment="Center"
                                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                                         BorderThickness="1.5"
                                         Margin="0,0,0,10"/>

                                <!-- حقل العنوان -->
                                <TextBlock Text="العنوان"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555" FontFamily="Segoe UI"
                                           Margin="0,0,0,5"/>
                                <TextBox Text="{Binding QuickAddAddress,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Height="38" FontFamily="Segoe UI" FontSize="13"
                                         Padding="10,0" VerticalContentAlignment="Center"
                                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                                         BorderThickness="1.5"
                                         Margin="0,0,0,12"/>

                                <!-- رسالة الخطأ -->
                                <Border Background="#FDEDEC" CornerRadius="6"
                                        Padding="10,6" Margin="0,0,0,10"
                                        Visibility="{Binding HasQuickAddError,
                                            Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding QuickAddError}"
                                               FontSize="12" Foreground="#E74C3C"
                                               FontFamily="Segoe UI"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- أزرار الحفظ / إلغاء -->
                                <StackPanel Orientation="Horizontal">
                                    <Button Command="{Binding SaveQuickAddCommand}"
                                            Height="36" Padding="18,0"
                                            FontSize="13" FontWeight="SemiBold"
                                            FontFamily="Segoe UI"
                                            Background="#1A73E8" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Margin="0,0,8,0">
                                        <TextBlock>
                                            <Run Text="💾 "/>
                                            <Run Text="حفظ وتحديد"/>
                                        </TextBlock>
                                    </Button>
                                    <Button Command="{Binding CancelQuickAddCommand}"
                                            Height="36" Padding="14,0"
                                            FontSize="13" FontFamily="Segoe UI"
                                            Background="White" Foreground="#7F8C8D"
                                            BorderThickness="1"
                                            BorderBrush="#DDE1E7" Cursor="Hand">
                                        <TextBlock Text="إلغاء"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- العميل المحدد -->
                        <Border Background="#EAFAF1" CornerRadius="8"
                                Padding="10,8" Margin="0,10,0,0"
                                Visibility="{Binding HasCustomer,
                                    Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text=" " FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           Foreground="#1E8449"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center">
                                    <Run Text="{Binding SelectedCustomer.FullName,
                                             TargetNullValue=''}"/>
                                    <Run Text=" — "/>
                                    <Run Text="{Binding SelectedCustomer.Phone,
                                             TargetNullValue=''}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- التاريخ -->
                        <TextBlock Text="تاريخ الفاتورة"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" FontFamily="Segoe UI"
                                   Margin="0,12,0,5"/>
                        <DatePicker SelectedDate="{Binding ReservationDate}"
                                    Height="38" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- ─── بيانات الدفع ─── -->
                <Border Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12" Padding="20"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text=" بيانات الدفع"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,14"/>

                        <!-- المبلغ المدفوع -->
                        <TextBlock Text="المبلغ المدفوع (ر.ي) "
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" FontFamily="Segoe UI"
                                   Margin="0,0,0,5"/>
                        <TextBox
                            Text="{Binding AmountPaid,
                                UpdateSourceTrigger=PropertyChanged}"
                            Height="42" FontSize="16" FontWeight="Bold"
                            FontFamily="Segoe UI"
                            Padding="12,0" VerticalContentAlignment="Center"
                            BorderBrush="{StaticResource ErpBrushBorderInput}"
                            BorderThickness="1.5"
                            Margin="0,0,0,12"/>

                        <!-- طريقة الدفع -->
                        <TextBlock Text="طريقة الدفع"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555" FontFamily="Segoe UI"
                                   Margin="0,0,0,5"/>
                        <ItemsControl ItemsSource="{Binding PaymentMethods}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Content="{Binding Name}"
                                                 GroupName="PaymentMethod"
                                                 Margin="0,0,16,0"
                                                 FontFamily="Segoe UI"
                                                 FontSize="13"
                                                 IsChecked="{Binding IsSelected}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- تفاصيل التحويل -->
                        <Grid Margin="0,12,0,0"
                              Visibility="{Binding ShowWallet,
                                  Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="المحفظة" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#555"
                                           FontFamily="Segoe UI" Margin="0,0,0,5"/>
                                <ComboBox ItemsSource="{Binding WalletOptions}"
                                          SelectedItem="{Binding WalletName}"
                                          Height="38" FontFamily="Segoe UI"
                                          Style="{StaticResource ErpFormComboBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="رقم العملية" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#555"
                                           FontFamily="Segoe UI" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding TransactionReference,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Height="38" FontFamily="Segoe UI"
                                         Padding="10,0" VerticalContentAlignment="Center"
                                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                                         BorderThickness="1.5"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── أصناف الحجز المحدد ─── -->
                <Border Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12" Padding="20"
                        Margin="0,0,0,12"
                        Visibility="{Binding IsQuantityReservation,
                            Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text=" أصناف الحجز"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,14"/>

                        <!-- إضافة صنف -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="المنتج" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#555"
                                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding AvailableProducts}"
                                          SelectedItem="{Binding SelectedProduct}"
                                          DisplayMemberPath="Name"
                                          Height="38" FontFamily="Segoe UI"
                                          Style="{StaticResource ErpFormComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="الكمية" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#555"
                                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding NewItemQuantity,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Height="38" FontFamily="Segoe UI"
                                         Padding="8,0" VerticalContentAlignment="Center"
                                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                                         BorderThickness="1.5"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock
                                    Text="{Binding NewItemPriceRange,
                                        FallbackValue='السعر (ر.ي)'}"
                                    FontSize="12" FontWeight="SemiBold"
                                    Foreground="#555" FontFamily="Segoe UI"
                                    Margin="0,0,0,4"/>
                                <TextBox Text="{Binding NewItemPrice,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Height="38" FontFamily="Segoe UI"
                                         Padding="8,0" VerticalContentAlignment="Center"
                                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                                         BorderThickness="1.5"/>
                            </StackPanel>

                            <Button Grid.Column="3"
                                    Content="➕ إضافة"
                                    Command="{Binding AddItemCommand}"
                                    Height="38" Padding="14,0"
                                    Background="#E67E22" Foreground="White"
                                    BorderThickness="0"
                                    FontFamily="Segoe UI" FontSize="13"
                                    Cursor="Hand"
                                    VerticalAlignment="Bottom"/>
                        </Grid>

                        <!--
                            ✅ جدول الأصناف — IsReadOnly="False" يسمح بتعديل
                            الكمية والسعر مباشرة في الجدول بدون إعادة إدخال.
                            الـ ViewModel مشترك في PropertyChanged لكل صنف
                            فيتحدث الإجمالي تلقائياً فور أي تعديل.
                        -->
                        <DataGrid ItemsSource="{Binding ReservationItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False"
                                  CanUserAddRows="False"
                                  Margin="0,12,0,0"
                                  MinHeight="80" RowHeight="40"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="المنتج"
                                    Binding="{Binding ProductName}"
                                    IsReadOnly="True" Width="*"/>
                                <DataGridTextColumn Header="الكمية"
                                    Binding="{Binding Quantity,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Width="80"/>
                                <DataGridTextColumn Header="السعر المثبت"
                                    Binding="{Binding UnitPrice,
                                        UpdateSourceTrigger=PropertyChanged,
                                        StringFormat=N0}"
                                    Width="100"/>
                                <DataGridTextColumn Header="الإجمالي"
                                    Binding="{Binding Total,
                                        StringFormat='{}{0:N0} ر.ي'}"
                                    IsReadOnly="True" Width="110"/>
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑" FontSize="14"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveItemCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ملاحظات -->
                <Border Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12" Padding="20"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="ملاحظات"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding Notes,
                                     UpdateSourceTrigger=PropertyChanged}"
                                 Height="60" TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 FontFamily="Segoe UI" Padding="10"
                                 BorderBrush="{StaticResource ErpBrushBorderInput}"
                                 BorderThickness="1.5"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ الملخص والحفظ ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="ملخص الفاتورة"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource ErpBrushNavSidebar}"
                               FontFamily="Segoe UI" Margin="0,0,0,16"/>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="العميل:" FontSize="12"
                                   Foreground="#555" FontFamily="Segoe UI"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedCustomer.FullName,
                                       TargetNullValue='—'}"/>
                    </Grid>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="نوع الحجز:" FontSize="12"
                                   Foreground="#555" FontFamily="Segoe UI"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   FontSize="13" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   TextWrapping="Wrap"
                                   Text="{Binding ReservationTypeLabel}"/>
                    </Grid>

                    <Separator Background="#F0F0F0" Margin="0,10"/>

                    <Grid Margin="0,6"
                          Visibility="{Binding IsQuantityReservation,
                              Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="إجمالي الأصناف:" FontSize="12"
                                   Foreground="#555" FontFamily="Segoe UI"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#E67E22" FontFamily="Segoe UI">
                            <Run Text="{Binding ItemsTotal, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                            <Run Text=" ر.ي"/>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="المبلغ المدفوع:" FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="#27AE60" FontFamily="Segoe UI">
                            <Run Text="{Binding AmountPaid, StringFormat='{}{0:N0}'}"/>
                            <Run Text=" ر.ي" FontSize="13"
                                 Foreground="{StaticResource ErpBrushTextSecondary}"/>
                        </TextBlock>
                    </Grid>

                    <!--
                        ✅ تنبيه الفرق — يظهر باللون الأصفر فوراً عند
                        عدم تطابق المبلغ المدفوع مع إجمالي الأصناف،
                        قبل أن يضغط المستخدم على حفظ.
                    -->
                    <Border Background="#FEF9E7"
                            BorderBrush="#F39C12"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,8" Margin="0,8,0,0"
                            Visibility="{Binding HasAmountMismatch,
                                Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding AmountMismatchHint}"
                                   Foreground="#D68910" FontSize="11"
                                   FontFamily="Segoe UI"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- رسالة الخطأ -->
                    <Border Background="#FDEDEC" CornerRadius="8"
                            Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding HasError,
                                Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#E74C3C" FontSize="12"
                                   FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </Border>

                    <!-- رسالة النجاح -->
                    <Border Background="#EAFAF1" CornerRadius="8"
                            Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding SuccessMessage,
                                Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="#27AE60" FontSize="12"
                                   FontFamily="Segoe UI"/>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <Button Content="💾 حفظ فاتورة الحجز"
                        Command="{Binding SaveCommand}"
                        Height="44" FontSize="14" FontWeight="Bold"
                        FontFamily="Segoe UI"
                        Background="{StaticResource ErpBrushNavSidebar}"
                        Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,0,8"/>

                <Button Content="🗑 مسح النموذج"
                        Command="{Binding ClearCommand}"
                        Height="36" FontSize="12" FontFamily="Segoe UI"
                        Background="{StaticResource ErpBrushPageBg}"
                        BorderBrush="{StaticResource ErpBrushBorderInput}"
                        BorderThickness="1" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
