<UserControl
    x:Class="BlockFactory.Desktop.Views.Reservations.ReservationsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- ══ القائمة الرئيسية ══ -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12" Padding="16,14"
                    Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text=" فواتير الحجز والرصيد"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource ErpBrushTextSecondary}"
                            FontFamily="Segoe UI" Margin="0,3,0,0">
                            <Run Text="إجمالي الحجوزات:"/>
                            <Run Text="{Binding Reservations.Count, Mode=OneWay}"
                                 FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="+ حجز جديد"
                            Command="{Binding NewReservationCommand}"
                            Height="38" Padding="16,0"
                            VerticalAlignment="Center"
                            Background="#E67E22" Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI" FontSize="13"
                            FontWeight="Bold" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- بحث وفلتر -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="0,0,8,0"
                        Background="{StaticResource ErpBrushCard}"
                        CornerRadius="8" Padding="10,0">
                    <TextBox
                        Text="{Binding SearchText,
                            UpdateSourceTrigger=PropertyChanged}"
                        BorderThickness="0" Background="Transparent"
                        Height="38" VerticalContentAlignment="Center"
                        FontFamily="Segoe UI" FontSize="13"
                        Foreground="{StaticResource ErpBrushTextPrimary}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Right">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="🔍 بحث برقم الفاتورة أو اسم العميل..."
                                                                   Foreground="#BDC3C7"
                                                                   FontFamily="Segoe UI"
                                                                   FontSize="13"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Border>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding FilterOptions}"
                          SelectedItem="{Binding SelectedFilter}"
                          Height="38"
                          FontFamily="Segoe UI" FontSize="12"
                          Style="{StaticResource ErpFormComboBox}"/>
            </Grid>

            <!-- رسائل -->
            <Border Grid.Row="2" Padding="12,8" CornerRadius="8"
                    Margin="0,0,0,8"
                    Visibility="{Binding HasError,
                        Converter={StaticResource BoolToVisibility}}"
                    Background="#FDEDEC">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E74C3C"
                           FontFamily="Segoe UI" FontSize="12"/>
            </Border>

            <!-- DataGrid -->
            <Border Grid.Row="2"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <DataGrid
                    ItemsSource="{Binding Reservations}"
                    SelectedItem="{Binding SelectedReservation}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="{StaticResource ErpBrushGridLine}"
                    HeadersVisibility="Column"
                    BorderThickness="0"
                    Background="{StaticResource ErpBrushCard}"
                    RowBackground="{StaticResource ErpBrushCard}"
                    AlternatingRowBackground="{StaticResource ErpBrushRowAlt}"
                    CanUserResizeRows="False"
                    SelectionMode="Single"
                    FontFamily="Segoe UI" FontSize="13"
                    RowHeight="44">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource ErpBrushTextSecondary}"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <!-- رقم الفاتورة -->
                        <DataGridTextColumn Header="رقم الفاتورة"
                            Binding="{Binding ReservationNumber}"
                            Width="140"/>

                        <!-- العميل -->
                        <DataGridTemplateColumn Header="العميل" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="12,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CustomerName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   FontFamily="Segoe UI"/>
                                        <TextBlock Text="{Binding CustomerPhone}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                                   FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- نوع الحجز -->
                        <DataGridTemplateColumn Header="النوع" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,3"
                                            Margin="8,8"
                                            HorizontalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush
                                                Color="{Binding TypeColor,
                                                    Converter={StaticResource StringToColorConverter}}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding TypeText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- المدفوع -->
                        <DataGridTextColumn Header="المدفوع"
                            Binding="{Binding AmountPaid,
                                StringFormat='{}{0:N0} ر.ي'}"
                            Width="110"/>

                        <!-- المتبقي -->
                        <DataGridTemplateColumn Header="المتبقي" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="{Binding AmountRemaining,
                                            StringFormat='{}{0:N0} ر.ي'}"
                                        FontWeight="Bold"
                                        FontSize="13"
                                        FontFamily="Segoe UI"
                                        VerticalAlignment="Center"
                                        Margin="12,0">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush
                                                Color="{Binding AmountRemaining,
                                                    Converter={StaticResource PositiveColorConverter}}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- الحالة -->
                        <DataGridTemplateColumn Header="الحالة" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,3"
                                            Margin="8,8"
                                            HorizontalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush
                                                Color="{Binding StatusColor,
                                                    Converter={StaticResource StringToColorConverter}}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   FontFamily="Segoe UI"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- التاريخ -->
                        <DataGridTextColumn Header="التاريخ"
                            Binding="{Binding ReservationDate,
                                StringFormat='{}{0:dd/MM/yyyy}'}"
                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- أزرار الإجراءات -->
            <Border Grid.Row="3"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12" Padding="14,10"
                    Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="📤 تنفيذ سحب"
                            Command="{Binding WithdrawCommand}"
                            Height="38" Padding="16,0"
                            Background="#27AE60" Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI" FontSize="13"
                            FontWeight="Bold" Cursor="Hand"
                            Margin="0,0,10,0"/>

                    <Button Content="❌ إلغاء الحجز"
                            Command="{Binding CancelCommand}"
                            Height="38" Padding="16,0"
                            Background="#E74C3C" Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI" FontSize="13"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══ تفاصيل الحجز ══ -->
        <Border Grid.Column="1"
                Background="{StaticResource ErpBrushCard}"
                CornerRadius="12" Padding="16"
                Visibility="{Binding HasSelection,
                    Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.05"
                                  BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="تفاصيل الحجز"
                               FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource ErpBrushNavSidebar}"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,14"/>

                    <!-- ملخص مالي -->
                    <Border Background="#F8F9FA" CornerRadius="8"
                            Padding="12,10" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="المدفوع:"
                                           FontSize="12" FontFamily="Segoe UI"
                                           Foreground="#555" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1"
                                           FontSize="13" FontWeight="Bold"
                                           FontFamily="Segoe UI"
                                           Foreground="{StaticResource ErpBrushNavSidebar}">
                                    <Run Text="{Binding Detail.AmountPaid,
                                        StringFormat='{}{0:N0}'}"/>
                                    <Run Text=" ر.ي"/>
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="المستهلك:"
                                           FontSize="12" FontFamily="Segoe UI"
                                           Foreground="#555" Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#E67E22"
                                           FontFamily="Segoe UI">
                                    <Run Text="{Binding Detail.AmountUsed,
                                        StringFormat='{}{0:N0}'}"/>
                                    <Run Text=" ر.ي"/>
                                </TextBlock>
                            </Grid>
                            <Separator Background="#E0E0E0" Margin="0,6"/>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="المتبقي:"
                                           FontSize="14" FontWeight="Bold"
                                           FontFamily="Segoe UI"
                                           Foreground="{StaticResource ErpBrushNavSidebar}"
                                           Margin="0,0,8,0"/>
                                <TextBlock Grid.Column="1"
                                           FontSize="16" FontWeight="Bold"
                                           Foreground="#27AE60"
                                           FontFamily="Segoe UI">
                                    <Run Text="{Binding Detail.AmountRemaining,
                                        StringFormat='{}{0:N0}'}"/>
                                    <Run Text=" ر.ي" FontSize="12"/>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- أصناف الحجز المحدد -->
                    <TextBlock Text="الأصناف المحجوزة"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource ErpBrushNavSidebar}"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,8"
                               Visibility="{Binding Detail.Items.Count,
                                   Converter={StaticResource CountToVisibility}}"/>

                    <ItemsControl
                        ItemsSource="{Binding Detail.Items}"
                        Visibility="{Binding Detail.Items.Count,
                            Converter={StaticResource CountToVisibility}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F9FA"
                                        CornerRadius="6" Padding="10,8"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ProductName}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       FontFamily="Segoe UI"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="#555"
                                                       FontFamily="Segoe UI">
                                                <Run Text="محجوز:"/>
                                                <Run Text="{Binding QuantityReserved,
                                                    StringFormat=N0}"
                                                     FontWeight="Bold"/>
                                                <Run Text=" | مسحوب:"/>
                                                <Run Text="{Binding QuantityWithdrawn,
                                                    StringFormat=N0}"/>
                                                <Run Text=" | متبقي:"/>
                                                <Run Text="{Binding QuantityRemaining,
                                                    StringFormat=N0}"
                                                     FontWeight="Bold"
                                                     Foreground="#27AE60"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   FontFamily="Segoe UI"
                                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                                   Margin="8,0,0,0">
                                            <Run Text="{Binding UnitPrice,
                                                StringFormat='{}{0:N0}'}"/>
                                            <Run Text=" ر.ي"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- سجلات السحب -->
                    <TextBlock Text="سجل السحوبات"
                               FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource ErpBrushNavSidebar}"
                               FontFamily="Segoe UI"
                               Margin="0,12,0,8"/>

                    <ItemsControl ItemsSource="{Binding Detail.Withdrawals}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#EAFAF1"
                                        CornerRadius="6" Padding="10,8"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock
                                                Text="{Binding WithdrawalNumber}"
                                                FontSize="12" FontWeight="SemiBold"
                                                FontFamily="Consolas"/>
                                            <TextBlock
                                                Text="{Binding WithdrawalDate,
                                                    StringFormat='{}{0:dd/MM/yyyy}'}"
                                                FontSize="11"
                                                Foreground="#555"
                                                FontFamily="Segoe UI"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#27AE60"
                                                   FontFamily="Segoe UI"
                                                   Margin="8,0,0,0">
                                            <Run Text="{Binding TotalAmount,
                                                StringFormat='{}{0:N0}'}"/>
                                            <Run Text=" ر.ي"/>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
