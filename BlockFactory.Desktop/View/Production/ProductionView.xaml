<UserControl
    x:Class="BlockFactory.Desktop.Views.Production.ProductionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Stats Cards -->
            <RowDefinition Height="Auto"/>
            <!-- Date + Toolbar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ─── بطاقات الإحصائيات ─── -->
        <UniformGrid Grid.Row="0" Columns="4"
                     Margin="0,0,0,14">

            <!-- إنتاج اليوم -->
            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="18,14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <TextBlock Text="إنتاج اليوم"
                                   FontSize="12" Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"/>
                        <Border Width="34" Height="34"
                                Background="#EBF5FB"
                                CornerRadius="10"
                                HorizontalAlignment="Left">
                            <TextBlock Text="🏭" FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <TextBlock
                        FontSize="28" FontWeight="Bold"
                        Foreground="{StaticResource ErpBrushNavSidebar}"
                        FontFamily="Segoe UI"
                        Margin="0,8,0,0">
                        <Run Text="{Binding Stats.TodayTotal,
                            FallbackValue='0'}"/>
                    </TextBlock>
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"
                               Margin="0,4,0,0">
                        <Run Text="تالف:"/>
                        <Run Text="{Binding Stats.TodayDefective,
                            FallbackValue='0'}"
                             Foreground="#E74C3C"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- إنتاج الأسبوع -->
            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="18,14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="إنتاج الأسبوع"
                               FontSize="12" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock
                        FontSize="28" FontWeight="Bold"
                        Foreground="#27AE60"
                        FontFamily="Segoe UI"
                        Margin="0,8,0,0">
                        <Run Text="{Binding Stats.WeekTotal,
                            FallbackValue='0'}"/>
                    </TextBlock>
                    <TextBlock Text="قطعة هذا الأسبوع"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- إنتاج الشهر -->
            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="18,14" Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="إنتاج الشهر"
                               FontSize="12" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock
                        FontSize="28" FontWeight="Bold"
                        Foreground="#E67E22"
                        FontFamily="Segoe UI"
                        Margin="0,8,0,0">
                        <Run Text="{Binding Stats.MonthTotal,
                            FallbackValue='0'}"/>
                    </TextBlock>
                    <TextBlock Text="قطعة هذا الشهر"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- نسبة التالف -->
            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="18,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="نسبة التالف اليوم"
                               FontSize="12" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock
                        FontSize="28" FontWeight="Bold"
                        FontFamily="Segoe UI"
                        Margin="0,8,0,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="#E74C3C"/>
                        </TextBlock.Foreground>
                        <Run Text="{Binding Stats.DefectiveRate,
                            FallbackValue='0',
                            StringFormat='{}{0:N1}'}"/>
                        <Run Text="%" FontSize="16"/>
                    </TextBlock>
                    <TextBlock Text="من إجمالي الإنتاج"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ─── Toolbar + Date Selector ─── -->
        <Border Grid.Row="1"
                Background="{StaticResource ErpBrushCard}"
                CornerRadius="12"
                Padding="16,12"
                Margin="0,0,0,14">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.05"
                                  BlurRadius="8" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- اختيار التاريخ -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="📅 عرض يوم:"
                               FontSize="13"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <DatePicker
                        SelectedDate="{Binding SelectedDate}"
                        Height="36" Width="160"
                        FontFamily="Segoe UI"/>
                </StackPanel>

                <!-- ملخص اليوم -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="13"
                               Foreground="#555"
                               FontFamily="Segoe UI">
                        <Run Text="إجمالي اليوم:"/>
                        <Run Text="{Binding DailySummary.TotalNet,
                            FallbackValue='0'}"
                             FontWeight="Bold"
                             Foreground="{StaticResource ErpBrushNavSidebar}"/>
                        <Run Text=" قطعة صافية"/>
                    </TextBlock>
                </StackPanel>

                <!-- أزرار -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="🗑 حذف"
                            Command="{Binding DeleteCommand}"
                            Visibility="{Binding CanDeleteProduction,
                                Converter={StaticResource BoolToVisibility}}"
                            Height="36" Padding="12,0"
                            Margin="0,0,8,0"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"/>

                    <Button Content="➕ تسجيل إنتاج"
                            Command="{Binding ShowFormCommand}"
                            Height="36" Padding="16,0"
                            Background="#E67E22"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            FontWeight="Bold"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── المحتوى الرئيسي ─── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- جدول السجلات + جدول المواد -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="180"/>
                </Grid.RowDefinitions>

                <!-- سجلات الإنتاج -->
                <Border Grid.Row="0"
                        Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12"
                        Margin="0,0,0,12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.05"
                                          BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{StaticResource ErpBrushBorder}"
                                BorderThickness="0,0,0,1">
                            <TextBlock Text="🏭 سجلات الإنتاج"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource ErpBrushTextPrimary}"
                                       FontFamily="Segoe UI"/>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Records}"
                                  SelectedItem="{Binding SelectedRecord}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource ErpBrushGridLine}"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="{StaticResource ErpBrushCard}"
                                  RowBackground="{StaticResource ErpBrushCard}"
                                  AlternatingRowBackground="{StaticResource ErpBrushRowAlt}"
                                  CanUserResizeRows="False"
                                  FontFamily="Segoe UI"
                                  FontSize="13"
                                  RowHeight="42">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"
                                            Value="#F8F9FA"/>
                                    <Setter Property="Foreground"
                                            Value="{StaticResource ErpBrushTextSecondary}"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding"
                                            Value="14,10"/>
                                    <Setter Property="BorderThickness"
                                            Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="النوع"
                                    Binding="{Binding ProductName}"
                                    Width="*"/>
                                <DataGridTextColumn Header="الوردية"
                                    Binding="{Binding Shift}"
                                    Width="80"/>
                                <DataGridTextColumn Header="المنتج"
                                    Binding="{Binding QuantityProduced}"
                                    Width="90"/>
                                <DataGridTextColumn Header="التالف"
                                    Binding="{Binding QuantityDefective}"
                                    Width="80"/>
                                <DataGridTemplateColumn
                                    Header="الصافي" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock
                                                Text="{Binding QuantityNet,
                                                    Mode=OneWay}"
                                                FontWeight="Bold"
                                                Foreground="#27AE60"
                                                VerticalAlignment="Center"
                                                Margin="14,0"
                                                FontFamily="Segoe UI"
                                                FontSize="13"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="ملاحظات"
                                    Binding="{Binding Notes}"
                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- المواد المستهلكة اليوم -->
                <TextBlock Grid.Row="1"
                           Text="🪨 المواد الخام المستهلكة اليوم"
                           FontSize="13" FontWeight="Bold"
                           Foreground="{StaticResource ErpBrushTextPrimary}"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,8"/>

                <Border Grid.Row="2"
                        Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.05"
                                          BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>
                    <DataGrid
                        ItemsSource="{Binding DailySummary.MaterialsConsumed}"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        GridLinesVisibility="Horizontal"
                        HorizontalGridLinesBrush="{StaticResource ErpBrushGridLine}"
                        HeadersVisibility="Column"
                        BorderThickness="0"
                        Background="{StaticResource ErpBrushCard}"
                        FontFamily="Segoe UI"
                        FontSize="13"
                        RowHeight="38">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"
                                        Value="#F8F9FA"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource ErpBrushTextSecondary}"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Padding" Value="14,8"/>
                                <Setter Property="BorderThickness"
                                        Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="المادة"
                                Binding="{Binding MaterialName}"
                                Width="*"/>
                            <DataGridTextColumn Header="المستهلك اليوم"
                                Binding="{Binding TotalConsumed}"
                                Width="120"/>
                            <DataGridTextColumn Header="الوحدة"
                                Binding="{Binding Unit}"
                                Width="80"/>
                            <DataGridTextColumn Header="المتبقي"
                                Binding="{Binding RemainingStock}"
                                Width="100"/>

                            <!-- تنبيه منخفض -->
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Text="⚠️"
                                            FontSize="14"
                                            HorizontalAlignment="Center"
                                            ToolTip="مخزون منخفض!"
                                            Visibility="{Binding IsLow,
                                                Converter={StaticResource BoolToVisibility}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- ─── نموذج التسجيل ─── -->
            <Border Grid.Column="1"
                    Width="380"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12"
                    Padding="20"
                    Visibility="{Binding IsFormVisible,
                        Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="🏭 تسجيل إنتاج جديد"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,16"/>

                        <!-- نوع البلوك -->
                        <TextBlock Text="نوع البلوك *"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,5"/>
                        <ComboBox
                            ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProduct}"
                            DisplayMemberPath="Name"
                            Height="38"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Margin="0,0,0,14"/>

                        <!-- الوردية -->
                        <TextBlock Text="الوردية"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,5"/>
                        <ComboBox
                            ItemsSource="{Binding Shifts}"
                            SelectedValuePath="Value"
                            DisplayMemberPath="Name"
                            SelectedValue="{Binding SelectedShift}"
                            Height="38"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Margin="0,0,0,14"/>

                        <!-- الكميات -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,8,0">
                                <TextBlock Text="الكمية المنتجة *"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#555"
                                           FontFamily="Segoe UI"
                                           Margin="0,0,0,5"/>
                                <TextBox
                                    Text="{Binding QuantityProduced,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Height="38"
                                    FontSize="13"
                                    FontFamily="Segoe UI"
                                    Padding="10,0"
                                    VerticalContentAlignment="Center"
                                    BorderBrush="{StaticResource ErpBrushBorderInput}"
                                    BorderThickness="1.5"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="الكمية التالفة"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#555"
                                           FontFamily="Segoe UI"
                                           Margin="0,0,0,5"/>
                                <TextBox
                                    Text="{Binding QuantityDefective,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Height="38"
                                    FontSize="13"
                                    FontFamily="Segoe UI"
                                    Padding="10,0"
                                    VerticalContentAlignment="Center"
                                    BorderBrush="{StaticResource ErpBrushBorderInput}"
                                    BorderThickness="1.5"/>
                            </StackPanel>
                        </Grid>

                        <!-- الصافي -->
                        <Border Background="#EAFAF1"
                                CornerRadius="8"
                                Padding="14,10"
                                Margin="0,0,0,14">
                            <TextBlock FontSize="14"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="#27AE60">
                                <Run Text="الصافي:"/>
                                <Run Text="{Binding QuantityNet,
                                    Mode=OneWay}"/>
                                <Run Text="قطعة"/>
                            </TextBlock>
                        </Border>

                        <!-- المواد الخام -->
                        <TextBlock Text="🪨 المواد الخام المستهلكة"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushTextPrimary}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,8"/>

                        <ItemsControl ItemsSource="{Binding MaterialUsages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding MaterialName}"
                                                   FontSize="13"
                                                   FontFamily="Segoe UI"
                                                   Foreground="{StaticResource ErpBrushTextPrimary}"
                                                   VerticalAlignment="Center"/>

                                        <TextBox Grid.Column="1"
                                                 Text="{Binding QuantityUsed,
                                                     UpdateSourceTrigger=PropertyChanged}"
                                                 Height="34"
                                                 Padding="8,0"
                                                 VerticalContentAlignment="Center"
                                                 FontSize="13"
                                                 FontFamily="Segoe UI"
                                                 BorderBrush="{StaticResource ErpBrushBorderInput}"
                                                 BorderThickness="1.5"
                                                 Margin="0,0,6,0"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Unit}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- ملاحظات -->
                        <TextBlock Text="ملاحظات"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555"
                                   FontFamily="Segoe UI"
                                   Margin="0,12,0,5"/>
                        <TextBox
                            Text="{Binding Notes,
                                UpdateSourceTrigger=PropertyChanged}"
                            Height="60"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalContentAlignment="Top"
                            FontSize="13"
                            FontFamily="Segoe UI"
                            Padding="10"
                            BorderBrush="{StaticResource ErpBrushBorderInput}"
                            BorderThickness="1.5"
                            Margin="0,0,0,16"/>

                        <!-- رسائل -->
                        <Border Background="#FDEDEC" CornerRadius="8"
                                Padding="10,6" Margin="0,0,0,10"
                                Visibility="{Binding HasError,
                                    Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#E74C3C"
                                       FontSize="12"
                                       FontFamily="Segoe UI"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="#EAFAF1" CornerRadius="8"
                                Padding="10,6" Margin="0,0,0,10"
                                Visibility="{Binding SuccessMessage,
                                    Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding SuccessMessage}"
                                       Foreground="#27AE60"
                                       FontSize="12"
                                       FontFamily="Segoe UI"/>
                        </Border>

                        <!-- أزرار -->
                        <Button Content="💾 حفظ الإنتاج"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource ErpPrimaryDarkButton}"
                                Margin="0,0,0,8"/>

                        <Button Content="إلغاء"
                                Command="{Binding HideFormCommand}"
                                Style="{StaticResource ErpSecondaryButton}"
                                Height="36"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
