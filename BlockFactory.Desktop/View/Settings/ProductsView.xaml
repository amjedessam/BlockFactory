<UserControl
    x:Class="BlockFactory.Desktop.Views.Settings.ProductsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="المنتجات والأسعار"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource ErpBrushNavSidebar}" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="{StaticResource ErpBrushCard}" CornerRadius="12" Padding="0">
            <DataGrid ItemsSource="{Binding Products}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="40"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="الاسم" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="النوع" Binding="{Binding TypeName}" Width="120"/>
                    <DataGridTextColumn Header="المقاس" Binding="{Binding Size}" Width="70"/>
                    <DataGridTextColumn Header="السعر الافتراضي" Binding="{Binding DefaultPrice, StringFormat=N0}" Width="120"/>
                    <DataGridCheckBoxColumn Header="نشط" Binding="{Binding IsActive}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
