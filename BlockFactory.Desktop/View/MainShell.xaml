<Window x:Class="BlockFactory.Desktop.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="نظام إدارة مصنع البلوك"
        Height="750" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        Background="{StaticResource ErpBrushPageBg}">

    <Window.Resources>
        <!-- Brushes: من EnterpriseTheme (دمج App)؛ تُبقى هنا فقط إن احتاجت لاحقاً أنماط خاصة بالنافذة -->

        <!-- Style: زر التنقل -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="8,2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="{StaticResource SidebarHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style: زر التنقل المحدد -->
        <Style x:Key="NavButtonActive"
               TargetType="Button"
               BasedOn="{StaticResource NavButton}">
            <Setter Property="Background"
                    Value="{StaticResource SidebarActive}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="{Binding SidebarWidth}"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════ -->
        <!-- SIDEBAR                               -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Column="0"
              Background="{StaticResource SidebarBg}">
            <Grid.RowDefinitions>
                <!-- Logo -->
                <RowDefinition Height="Auto"/>
                <!-- Menu -->
                <RowDefinition Height="*"/>
                <!-- User Profile -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── Logo Area ─── -->
            <Border Grid.Row="0"
                    Padding="16,20"
                    BorderBrush="#2C4F7C"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- أيقونة -->
                    <Border Grid.Column="0"
                            Width="38" Height="38"
                            Background="{StaticResource SidebarActive}"
                            CornerRadius="10">
                        <TextBlock Text="🏭"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- اسم النظام -->
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsSidebarExpanded,
                                    Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="مصنع البلوك"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextLight}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="نظام الإدارة"
                                   FontSize="10"
                                   Foreground="{StaticResource TextMuted}"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- زر طي السايدبار -->
                    <Button Grid.Column="2"
                            Command="{Binding ToggleSidebarCommand}"
                            Width="28" Height="28"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="طي القائمة">
                        <TextBlock Text="☰"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ─── Navigation Menu ─── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding MenuGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4,0,0">

                                <!-- عنوان المجموعة -->
                                <TextBlock
                                    Text="{Binding GroupTitle}"
                                    FontSize="10"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource TextMuted}"
                                    FontFamily="Segoe UI"
                                    Margin="20,8,0,4"
                                    Visibility="{Binding DataContext.IsSidebarExpanded,
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        Converter={StaticResource BoolToVisibility}}"/>

                                <!-- عناصر القائمة -->
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Style="{StaticResource NavButton}"
                                                Command="{Binding DataContext.NavigateCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding ViewName}"
                                                ToolTip="{Binding Title}">
                                                <Grid Margin="12,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- الأيقونة -->
                                                    <TextBlock
                                                        Grid.Column="0"
                                                        Text="{Binding Icon}"
                                                        FontSize="16"
                                                        VerticalAlignment="Center"
                                                        Width="24"
                                                        TextAlignment="Center"/>

                                                    <!-- العنوان -->
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Text="{Binding Title}"
                                                        FontSize="13"
                                                        Foreground="{StaticResource TextLight}"
                                                        FontFamily="Segoe UI"
                                                        VerticalAlignment="Center"
                                                        Margin="10,0,0,0"
                                                        Visibility="{Binding DataContext.IsSidebarExpanded,
                                                            RelativeSource={RelativeSource AncestorType=Window},
                                                            Converter={StaticResource BoolToVisibility}}"/>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- فاصل -->
                                <Separator Background="#2C4F7C"
                                           Margin="16,8"
                                           Opacity="0.5"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ─── User Profile ─── -->
            <Border Grid.Row="2"
                    BorderBrush="#2C4F7C"
                    BorderThickness="0,1,0,0"
                    Padding="12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0"
                            Width="36" Height="36"
                            Background="{StaticResource SidebarActive}"
                            CornerRadius="18">
                        <TextBlock
                            Text="{Binding UserInitials}"
                            Foreground="White"
                            FontSize="13"
                            FontWeight="Bold"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Name & Role -->
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsSidebarExpanded,
                                    Converter={StaticResource BoolToVisibility}}">
                        <TextBlock
                            Text="{Binding UserFullName}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextLight}"
                            FontFamily="Segoe UI"/>
                        <TextBlock
                            Text="{Binding UserRole}"
                            FontSize="10"
                            Foreground="{StaticResource TextMuted}"
                            FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- زر تسجيل الخروج -->
                    <Button Grid.Column="2"
                            Command="{Binding LogoutCommand}"
                            Width="30" Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="تسجيل الخروج"
                            Visibility="{Binding IsSidebarExpanded,
                                Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="🚪"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════ -->
        <!-- MAIN CONTENT AREA                     -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Header -->
                <RowDefinition Height="60"/>
                <!-- Content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ─── Top Header ─── -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderBg}"
                    BorderBrush="#E5E9EF"
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- عنوان الصفحة الحالية -->
                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <TextBlock Text="🏠"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock
                            Text="{Binding CurrentViewTitle}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource ErpBrushTextPrimary}"
                            FontFamily="Segoe UI"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- الوقت والتاريخ -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                        <TextBlock
                            Text="{Binding CurrentTime}"
                            FontSize="14"
                            Foreground="{StaticResource ErpBrushTextSecondary}"
                            FontFamily="Segoe UI"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── Page Content ─── -->
            <Border Grid.Row="1"
                    Background="{StaticResource ContentBg}"
                    Padding="{StaticResource ErpPaddingPage}">
                <ContentControl x:Name="MainFrame"/>
            </Border>
        </Grid>
    </Grid>
</Window>
