<Window x:Class="BlockFactory.Desktop.MainShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="نظام إدارة مصنع البلوك"
        Height="750" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        FlowDirection="RightToLeft"
        Background="{StaticResource ErpBrushPageBg}">

    <Window.Resources>
        <!-- ═══════════════════════════════════════════ -->
        <!-- NavButton: Professional navigation button   -->
        <!-- ═══════════════════════════════════════════ -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Active indicator vertical bar (left side in LTR = right visual in RTL) -->
                            <Border x:Name="activeBar"
                                    HorizontalAlignment="Right"
                                    Width="4"
                                    CornerRadius="2,0,0,2"
                                    Background="{StaticResource SidebarActive}"
                                    Opacity="0"/>

                            <!-- Main content area -->
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Margin="8,2,8,2"
                                    Padding="0">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="{StaticResource SidebarHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Group Header Button style -->
        <Style x:Key="GroupHeaderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Margin="8,0" Padding="10,0" CornerRadius="4">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Star (Favorite) Toggle Button -->
        <Style x:Key="FavStarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.3"/> <!-- Starts slightly visible for better affordance -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="{Binding SidebarWidth}"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════ -->
        <!-- SIDEBAR                               -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Column="0"
              Background="{StaticResource SidebarBg}">
            <Grid.RowDefinitions>
                <!-- Logo & Toggle -->
                <RowDefinition Height="Auto"/>
                <!-- Menu -->
                <RowDefinition Height="*"/>
                <!-- User Profile -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── Header Area & Toggle ─── -->
            <Border Grid.Row="0"
                    Padding="12,18"
                    BorderBrush="{StaticResource SidebarSeparator}"
                    BorderThickness="0,0,0,1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1A3050" Offset="0.0" />
                        <GradientStop Color="#0F1E30" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- زر طي السايدبار (Toggle Button) -->
                    <Button Grid.Column="0"
                            Command="{Binding ToggleSidebarCommand}"
                            Width="36" Height="36"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="طي / فتح القائمة">
                        <Border Background="#1E3F6E" CornerRadius="8">
                            <TextBlock Foreground="{StaticResource SidebarIconNormal}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="☰"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="True">
                                                <Setter Property="Text" Value="✕"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Button>

                    <!-- اسم النظام -->
                    <StackPanel Grid.Column="1"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="مصنع الكولي"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SidebarTextNormal}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="نظام الإدارة"
                                   FontSize="11"
                                   Foreground="{StaticResource SidebarGroupHeader}"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── Navigation Menu ─── -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,8,0,0">
                <StackPanel>

                    <!-- ═══ FAVORITES SECTION ═══ -->
                    <StackPanel Visibility="{Binding HasFavorites, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="المفضلة"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SidebarGroupHeader}"
                                   FontFamily="Segoe UI"
                                   Margin="20,8,0,8"
                                   Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}"/>

                        <ItemsControl ItemsSource="{Binding FavoriteItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button ToolTip="{Binding Title}"
                                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding ViewName}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource SidebarActiveSubtle}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Grid Margin="12,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Vertical Bar Indicator -->
                                            <Border Grid.Column="0"
                                                    x:Name="FavActiveBar"
                                                    HorizontalAlignment="Right"
                                                    Width="3"
                                                    Height="26"
                                                    CornerRadius="0"
                                                    Margin="0,0,-10,0"
                                                    Background="{StaticResource SidebarActive}"
                                                    Opacity="0"/>

                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="18" VerticalAlignment="Center" Width="28" TextAlignment="Center" Foreground="{StaticResource SidebarIconNormal}" x:Name="FavIcon"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="13" FontWeight="Medium" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource SidebarTextNormal}" Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}" x:Name="FavText"/>
                                        </Grid>
                                        <Button.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="FavActiveBar" Storyboard.TargetProperty="Opacity" Duration="0" To="0"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Button.Triggers>
                                    </Button>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="FavActiveBar" Property="Opacity" Value="1"/>
                                            <Setter TargetName="FavIcon" Property="Foreground" Value="{StaticResource SidebarActive}"/>
                                            <Setter TargetName="FavText" Property="Foreground" Value="{StaticResource SidebarActive}"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="{StaticResource SidebarSeparator}" Margin="16,8" Height="1" BorderThickness="0"/>
                    </StackPanel>

                    <!-- ═══ MENU GROUPS ═══ -->
                    <ItemsControl ItemsSource="{Binding MenuGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,0">

                                    <!-- ─── Group Header (Accordion Toggle) ─── -->
                                    <Button Style="{StaticResource GroupHeaderButton}"
                                            Command="{Binding DataContext.ToggleGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding GroupTitle}"
                                            Visibility="{Binding DataContext.IsSidebarExpanded, Converter={StaticResource BoolToVisibility}, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Group Header: #8ab4d4 (SidebarGroupHeader) with 600 weight (SemiBold) -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding GroupTitle}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SidebarGroupHeader}"
                                                       FontFamily="Segoe UI"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1" FontSize="12" Foreground="{StaticResource SidebarGroupHeader}" VerticalAlignment="Center" Margin="4,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="▾"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Text" Value="◂"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Button>

                                    <!-- ─── Group Items (Collapsible) ─── -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid x:Name="navItemRow">
                                                    <Button ToolTip="{Binding Title}"
                                                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding ViewName}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource SidebarActiveSubtle}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <Grid Margin="12,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Vertical bar active indicator (Right visually in RTL) -->
                                                            <Border Grid.Column="0"
                                                                    x:Name="ItemActiveBar"
                                                                    HorizontalAlignment="Right"
                                                                    Width="3"
                                                                    Height="26"
                                                                    CornerRadius="0"
                                                                    Margin="0,0,-10,0"
                                                                    Background="{StaticResource SidebarActive}"
                                                                    Opacity="0"/>

                                                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="18" VerticalAlignment="Center" Width="28" TextAlignment="Center" Foreground="{StaticResource SidebarIconNormal}" x:Name="ItemIcon"/>

                                                            <!-- Menu Item Text (13px, weight 500=Medium) -->
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Title}"
                                                                       FontSize="13"
                                                                       FontWeight="Medium"
                                                                       FontFamily="Segoe UI"
                                                                       VerticalAlignment="Center"
                                                                       Margin="10,0,0,0"
                                                                       Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                                                                       x:Name="ItemText"
                                                                       Foreground="{StaticResource SidebarTextNormal}"/>

                                                            <!-- Star favorite button -->
                                                            <Button x:Name="StarBtn" 
                                                                    Grid.Column="2"
                                                                    Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource FavStarButton}"
                                                                    Visibility="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock FontSize="16" VerticalAlignment="Center" Padding="0,0,0,3">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="☆"/>
                                                                            <Setter Property="Foreground" Value="{StaticResource SidebarFavoriteStarOff}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                                    <Setter Property="Text" Value="★"/>
                                                                                    <Setter Property="Foreground" Value="{StaticResource SidebarFavoriteStar}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Button>
                                                        </Grid>
                                                    </Button>
                                                </Grid>

                                                <!-- DataTemplate triggers to handle active states -->
                                                <DataTemplate.Triggers>
                                                    <EventTrigger RoutedEvent="Mouse.MouseEnter">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="StarBtn" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <EventTrigger RoutedEvent="Mouse.MouseLeave">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="StarBtn" Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                        <Setter TargetName="StarBtn" Property="Opacity" Value="1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="ItemActiveBar" Property="Opacity" Value="1"/>
                                                        <Setter TargetName="ItemIcon" Property="Foreground" Value="{StaticResource SidebarActive}"/>
                                                        <Setter TargetName="ItemText" Property="Foreground" Value="{StaticResource SidebarActive}"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Separator between groups -->
                                    <Separator Background="{StaticResource SidebarSeparator}" Margin="16,6" Height="1" BorderThickness="0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ─── User Profile ─── -->
            <Border Grid.Row="2"
                    Background="{StaticResource SidebarBg}"
                    BorderBrush="#21416A"
                    BorderThickness="0,1,0,0"
                    Padding="12,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="36" Height="36"
                            Background="{StaticResource SidebarActiveBg}"
                            CornerRadius="18"
                            ToolTip="{Binding UserFullName}">
                        <TextBlock Text="{Binding UserInitials}"
                                   Foreground="White" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding UserFullName}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource SidebarTextNormal}" FontFamily="Segoe UI"/>
                        <TextBlock Text="{Binding UserRole}" FontSize="11" Foreground="{StaticResource SidebarGroupHeader}" FontFamily="Segoe UI"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Command="{Binding LogoutCommand}"
                            Width="32" Height="32" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="تسجيل الخروج"
                            Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}">
                        <Border Background="#22FFFFFF" CornerRadius="6" Padding="4">
                            <TextBlock Text="🚪" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════ -->
        <!-- MAIN CONTENT AREA                     -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderBrush="#E5E9EF" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="{Binding CurrentViewTitle}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource ErpBrushTextPrimary}" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding CurrentTime}" FontSize="15" Foreground="{StaticResource ErpBrushTextSecondary}" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource ContentBg}" Padding="{StaticResource ErpPaddingPage}">
                <ContentControl x:Name="MainFrame"/>
            </Border>
        </Grid>
    </Grid>
</Window>
