<UserControl
    x:Class="BlockFactory.Desktop.Views.Orders.NewOrderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BlockFactory.Desktop.Converters"
    FlowDirection="RightToLeft"
    Background="#F0F2F5"
    Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1E3A5F"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#DDE1E7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ستايل RadioButton لأزرار طريقة الدفع -->
        <Style x:Key="PaymentRadioBtn" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- العمود الأيمن — تفاصيل الطلب -->
            <ColumnDefinition Width="*"/>
            <!-- العمود الأيسر — الإجماليات -->
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════ -->
        <!-- العمود الأيمن                             -->
        <!-- ══════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,14,0">
            <StackPanel>

                <!-- ─── بيانات العميل ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text=" بيانات العميل"
                                   Style="{StaticResource SectionTitle}"/>

                        <TextBlock Text="ابحث عن العميل"
                                   Style="{StaticResource FieldLabel}"/>

                        <!-- حقل البحث مع Popup -->
                        <Grid>
                            <TextBox
                                Style="{StaticResource InputBox}"
                                Text="{Binding CustomerSearch,
                                    UpdateSourceTrigger=PropertyChanged}"
                                x:Name="CustomerSearchBox"/>

                            <!-- نتائج البحث -->
                            <Popup
                                IsOpen="{Binding CustomerResults.Count,
                                    Converter={StaticResource CountToBool},
                                    Mode=OneWay}"
                                PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                                Placement="Bottom"
                                Width="{Binding ActualWidth,
                                    ElementName=CustomerSearchBox}"
                                StaysOpen="False">
                                <Border Background="White"
                                        BorderBrush="#DDE1E7"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000"
                                            Opacity="0.1"
                                            BlurRadius="10"
                                            ShadowDepth="3"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <ListBox
    x:Name="CustomerListBox"
    ItemsSource="{Binding CustomerResults}"
    BorderThickness="0"
    MaxHeight="200"
    FontFamily="Segoe UI"
    MouseLeftButtonUp="CustomerListBox_MouseLeftButtonUp">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="10,6">
                                                        <TextBlock
                                                            Text="{Binding FullName}"
                                                            FontSize="13"
                                                            FontWeight="SemiBold"
                                                            Foreground="#2C3E50"/>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock
                                                                Text="{Binding Phone}"
                                                                FontSize="11"
                                                                Foreground="#7F8C8D"
                                                                Margin="0,0,10,0"/>
                                                            <TextBlock
                                                                FontSize="11"
                                                                Foreground="#E74C3C"
                                                                Visibility="{Binding TotalDebt,
                                                                    Converter={StaticResource DecimalToBool}}">
                                                                <Run Text="دين:"/>
                                                                <Run Text="{Binding TotalDebt,
                                                                    StringFormat='{}{0:N0} ر.ي'}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- زر إضافة عميل جديد أسفل حقل البحث -->
                        <Button
                            Command="{Binding ShowQuickAddCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Padding="8,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="➕ "
                                           FontSize="12"
                                           Foreground="#21416A"/>
                                <TextBlock Text="إضافة عميل جديد"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#21416A"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Button>

                        <!-- ── نموذج الإضافة السريعة ── -->
                        <Border
                            Visibility="{Binding IsQuickAddVisible,
                                Converter={StaticResource BoolToVisibility}}"
                            Background="#F0F7FF"
                            BorderBrush="#1A73E8"
                            BorderThickness="1.5"
                            CornerRadius="10"
                            Padding="16"
                            Margin="0,10,0,0">
                            <StackPanel>

                                <!-- رأس النموذج -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal">
                                        <TextBlock Text="➕ "
                                                   FontSize="14"
                                                   Foreground="#21416A"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="إضافة عميل جديد"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#1A2E4A"
                                                   FontFamily="Segoe UI"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            Command="{Binding CancelQuickAddCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#7F8C8D"
                                            FontSize="13"
                                            Cursor="Hand"
                                            Padding="4"/>
                                </Grid>

                                <!-- حقل الاسم -->
                                <TextBlock Text="الاسم كامل"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}"
                                         Text="{Binding QuickAddName,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,10"/>

                                <!-- حقل الهاتف -->
                                <TextBlock Text="رقم الهاتف"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}"
                                         Text="{Binding QuickAddPhone,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,10"/>

                                <!-- حقل العنوان -->
                                <TextBlock Text="العنوان"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox Style="{StaticResource InputBox}"
                                         Text="{Binding QuickAddAddress,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,0,12"/>

                                <!-- رسالة الخطأ -->
                                <Border Background="#FDEDEC"
                                        CornerRadius="6"
                                        Padding="10,6"
                                        Margin="0,0,0,10"
                                        Visibility="{Binding HasQuickAddError,
                                            Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding QuickAddError}"
                                               FontSize="12"
                                               Foreground="#E74C3C"
                                               FontFamily="Segoe UI"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- أزرار الحفظ / إلغاء -->
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Command="{Binding SaveQuickAddCommand}"
                                        Height="36"
                                        Padding="18,0"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        FontFamily="Segoe UI"
                                        Background="#1A73E8"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,8,0">
                                        <TextBlock>
                                            <Run Text="💾 "/>
                                            <Run Text="حفظ وتحديد"/>
                                        </TextBlock>
                                    </Button>
                                    <Button
                                        Command="{Binding CancelQuickAddCommand}"
                                        Height="36"
                                        Padding="14,0"
                                        FontSize="13"
                                        FontFamily="Segoe UI"
                                        Background="White"
                                        Foreground="#7F8C8D"
                                        BorderThickness="1"
                                        BorderBrush="#DDE1E7"
                                        Cursor="Hand">
                                        <TextBlock Text="إلغاء"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- تحذير الدين -->
                        <TextBlock
                            Text="{Binding CustomerDebtText}"
                            FontSize="12"
                            FontFamily="Segoe UI"
                            Margin="0,6,0,0"
                            Foreground="#E74C3C"
                            Visibility="{Binding HasSelectedCustomer,
                                Converter={StaticResource BoolToVisibility}}"/>

                        <!-- تاريخ الطلب + تاريخ الاستحقاق -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="تاريخ الطلب"
                                           Style="{StaticResource FieldLabel}"/>
                                <DatePicker
                                    SelectedDate="{Binding OrderDate}"
                                    Height="38"
                                    FontFamily="Segoe UI"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Visibility="{Binding ShowDueDate,
                                            Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="تاريخ الاستحقاق"
                                           Style="{StaticResource FieldLabel}"/>
                                <DatePicker
                                    SelectedDate="{Binding DueDate}"
                                    Height="38"
                                    FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── طريقة الدفع ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text=" طريقة الدفع"
                                   Style="{StaticResource SectionTitle}"/>

                        <!--
                            ✅ الإصلاح الجوهري:
                            كل RadioButton يربط مباشرة على SelectedPaymentType
                            عبر EnumBoolConverter بدلاً من IsSelected/SelectPaymentTypeCommand
                            اللذين لا وجود لهما.
                        -->
                        <WrapPanel Margin="0,0,0,4">
                            <RadioButton
                                Content="نقد"
                                GroupName="Payment"
                                Style="{StaticResource PaymentRadioBtn}"
                                IsChecked="{Binding SelectedPaymentType,
                                    Converter={StaticResource EnumBoolConverter},
                                    ConverterParameter='Cash'}"/>

                            <RadioButton
                                Content="تحويل"
                                GroupName="Payment"
                                Style="{StaticResource PaymentRadioBtn}"
                                IsChecked="{Binding SelectedPaymentType,
                                    Converter={StaticResource EnumBoolConverter},
                                    ConverterParameter='Electronic'}"/>

                            <RadioButton
                                Content="آجل"
                                GroupName="Payment"
                                Style="{StaticResource PaymentRadioBtn}"
                                IsChecked="{Binding SelectedPaymentType,
                                    Converter={StaticResource EnumBoolConverter},
                                    ConverterParameter='Credit'}"/>

                            <RadioButton
                                Content="رهن"
                                GroupName="Payment"
                                Style="{StaticResource PaymentRadioBtn}"
                                IsChecked="{Binding SelectedPaymentType,
                                    Converter={StaticResource EnumBoolConverter},
                                    ConverterParameter='Pledge'}"/>

                            <RadioButton
                                Content="مختلط"
                                GroupName="Payment"
                                Style="{StaticResource PaymentRadioBtn}"
                                Margin="0"
                                IsChecked="{Binding SelectedPaymentType,
                                    Converter={StaticResource EnumBoolConverter},
                                    ConverterParameter='Mixed'}"/>
                        </WrapPanel>

                        <!-- تفاصيل التحويل الإلكتروني -->
                        <Grid Margin="0,12,0,0"
                              Visibility="{Binding ShowWallet,
                                  Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="المحفظة"
                                           Style="{StaticResource FieldLabel}"/>
                                <ComboBox
                                    ItemsSource="{Binding WalletOptions}"
                                    SelectedItem="{Binding SelectedWallet}"
                                    Height="38"
                                    FontFamily="Segoe UI"
                                    FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="رقم العملية"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox
                                    Style="{StaticResource InputBox}"
                                    Text="{Binding TransactionReference,
                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- الدفعة الأولى للآجل / الرهن / المختلط -->
                        <StackPanel
                            Margin="0,12,0,0"
                            Visibility="{Binding ShowInitialPayment,
                                Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="الدفعة الأولى (ر.ي)"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox
                                Style="{StaticResource InputBox}"
                                Width="200"
                                HorizontalAlignment="Right"
                                Text="{Binding InitialPayment,
        UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── بيانات الرهن ─── -->
                <Border Style="{StaticResource SectionCard}"
                        Visibility="{Binding IsPledge,
                            Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text=" بيانات الرهن"
                                   Style="{StaticResource SectionTitle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="نوع الرهن"
                                           Style="{StaticResource FieldLabel}"/>
                                <ComboBox
                                    ItemsSource="{Binding PledgeTypes}"
                                    SelectedValuePath="Value"
                                    DisplayMemberPath="Name"
                                    SelectedValue="{Binding SelectedPledgeType}"
                                    Height="38"
                                    FontFamily="Segoe UI"
                                    FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="تاريخ السداد"
                                           Style="{StaticResource FieldLabel}"/>
                                <DatePicker
                                    SelectedDate="{Binding PledgeDueDate}"
                                    Height="38"
                                    FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="وصف الرهن"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,12,0,5"/>
                        <TextBox
                            Style="{StaticResource InputBox}"
                            Text="{Binding PledgeDescription,
                                UpdateSourceTrigger=PropertyChanged}"
                            Height="60"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalContentAlignment="Top"
                            Padding="10"/>

                        <TextBlock Text="ملاحظات الرهن"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,10,0,5"/>
                        <TextBox
                            Style="{StaticResource InputBox}"
                            Text="{Binding PledgeNotes,
                                UpdateSourceTrigger=PropertyChanged}"
                            Height="50"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalContentAlignment="Top"
                            Padding="10"/>
                    </StackPanel>
                </Border>

                <!-- ─── إضافة منتجات ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text=" المنتجات"
                                   Style="{StaticResource SectionTitle}"/>

                        <!-- صف إضافة منتج -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- اختيار المنتج -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="المنتج"
                                           Style="{StaticResource FieldLabel}"/>
                                <ComboBox
                                    ItemsSource="{Binding AvailableProducts}"
                                    SelectedItem="{Binding SelectedProduct}"
                                    DisplayMemberPath="Name"
                                    Height="38"
                                    FontFamily="Segoe UI"
                                    FontSize="13"/>
                            </StackPanel>

                            <!-- الكمية -->
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="الكمية"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox
                                    Style="{StaticResource InputBox}"
                                    Text="{Binding NewItemQuantity,
                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <!-- السعر -->
                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock
                                    Text="{Binding NewItemPriceRange,
                                        FallbackValue='السعر (ر.ي)'}"
                                    Style="{StaticResource FieldLabel}"/>
                                <TextBox
                                    Style="{StaticResource InputBox}"
                                    Text="{Binding NewItemPrice,
                                        UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Background>
                                        <SolidColorBrush
                                            Color="{Binding IsPriceValid,
                                                Converter={StaticResource BoolToColorConverter},
                                                ConverterParameter='White|#FDEDEC'}"/>
                                    </TextBox.Background>
                                </TextBox>
                            </StackPanel>

                            <!-- زر الإضافة -->
                            <Button Grid.Column="3"
                                    Style="{StaticResource ActionBtn}"
                                    Content="➕ إضافة"
                                    Command="{Binding AddItemCommand}"
                                    Background="#E67E22"
                                    Foreground="White"
                                    VerticalAlignment="Bottom"/>
                        </Grid>

                        <!-- جدول المنتجات المضافة -->
                        <DataGrid
                            ItemsSource="{Binding OrderItems}"
                            AutoGenerateColumns="False"
                            IsReadOnly="False"
                            CanUserAddRows="False"
                            GridLinesVisibility="Horizontal"
                            HorizontalGridLinesBrush="#F0F2F5"
                            HeadersVisibility="Column"
                            BorderThickness="1"
                            BorderBrush="#F0F2F5"
                            Background="White"
                            RowBackground="White"
                            AlternatingRowBackground="#FAFBFC"
                            Margin="0,12,0,0"
                            MinHeight="120"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            RowHeight="40">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F8F9FA"/>
                                    <Setter Property="Foreground" Value="#7F8C8D"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Header="المنتج"
                                    Binding="{Binding ProductName}"
                                    IsReadOnly="True"
                                    Width="*"/>

                                <DataGridTextColumn
                                    Header="المخزون"
                                    Binding="{Binding AvailableStock}"
                                    IsReadOnly="True"
                                    Width="80"/>

                                <DataGridTextColumn
                                    Header="الكمية"
                                    Binding="{Binding Quantity,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Width="80"/>

                                <DataGridTextColumn
                                    Header="السعر"
                                    Binding="{Binding UnitPrice,
                                        UpdateSourceTrigger=PropertyChanged,
                                        StringFormat='{}{0:N0}'}"
                                    Width="100"/>

                                <DataGridTextColumn
                                    Header="الإجمالي"
                                    Binding="{Binding TotalPrice,
                                        StringFormat='{}{0:N0} ر.ي'}"
                                    IsReadOnly="True"
                                    Width="120"/>

                                <!-- زر الحذف -->
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑"
                                                    FontSize="14"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveItemCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ─── طريقة التوصيل ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="🚛 التوصيل"
                                   Style="{StaticResource SectionTitle}"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <RadioButton
                                Content="استلام من المصنع"
                                GroupName="Delivery"
                                IsChecked="{Binding SelectedDeliveryType,
                                    Converter={StaticResource EnumBoolConverter},
                                    ConverterParameter='Pickup'}"
                                FontFamily="Segoe UI"
                                FontSize="13"
                                Margin="0,0,20,0"/>

                            <RadioButton
                                Content="توصيل للعميل"
                                GroupName="Delivery"
                                IsChecked="{Binding SelectedDeliveryType,
                                    Converter={StaticResource EnumBoolConverter},
                                    ConverterParameter='Delivery'}"
                                FontFamily="Segoe UI"
                                FontSize="13"/>
                        </StackPanel>

                        <!-- تكلفة التوصيل -->
                        <StackPanel
                            Orientation="Horizontal"
                            Visibility="{Binding IsDelivery,
                                Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="تكلفة التوصيل (ر.ي):"
                                       Style="{StaticResource FieldLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBox
                                Style="{StaticResource InputBox}"
                                Width="150"
                                Text="{Binding DeliveryCost,
                                    UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── ملاحظات ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="📝 ملاحظات"
                                   Style="{StaticResource SectionTitle}"/>
                        <TextBox
                            Text="{Binding Notes,
                                UpdateSourceTrigger=PropertyChanged}"
                            Height="70"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalContentAlignment="Top"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Padding="10"
                            BorderBrush="#DDE1E7"
                            BorderThickness="1.5"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════ -->
        <!-- العمود الأيسر — الإجماليات والحفظ         -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- بطاقة الإجماليات -->
            <Border Grid.Row="0"
        Background="White"
        CornerRadius="12"
        Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                          BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="ملخص الطلب"
                   Style="{StaticResource SectionTitle}"/>

                    <!-- عميل -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="العميل:"
                       FontSize="12" Foreground="#7F8C8D"
                       FontFamily="Segoe UI" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                       Text="{Binding SelectedCustomer.FullName, FallbackValue='---'}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#2C3E50" FontFamily="Segoe UI"/>
                    </Grid>

                    <!-- نوع الدفع -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="طريقة الدفع:"
                       FontSize="12" Foreground="#7F8C8D"
                       FontFamily="Segoe UI" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                       Text="{Binding SelectedPaymentType}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#1E3A5F" FontFamily="Segoe UI"/>
                    </Grid>

                    <Separator Background="#F0F2F5" Margin="0,8"/>

                    <!-- المجموع الفرعي -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="المجموع الفرعي:"
                       FontSize="13" Foreground="#555"
                       FontFamily="Segoe UI" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" FontSize="13"
                       Foreground="#2C3E50" FontFamily="Segoe UI">
                <Run Text="{Binding SubTotal, StringFormat='{}{0:N0}'}"/>
                <Run Text=" ر.ي"/>
                        </TextBlock>
                    </Grid>

                    <!-- الخصم (يظهر فقط إذا وجد) -->
                    <Grid Margin="0,4"
              Visibility="{Binding Discount, Converter={StaticResource DecimalToBool}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="الخصم:"
                       FontSize="13" Foreground="#E74C3C"
                       FontFamily="Segoe UI" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" FontSize="13"
                       Foreground="#E74C3C" FontFamily="Segoe UI">
                <Run Text="-"/>
                <Run Text="{Binding Discount, StringFormat='{}{0:N0}'}"/>
                <Run Text=" ر.ي"/>
                        </TextBlock>
                    </Grid>

                    <!-- إدخال الخصم -->
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="خصم (ر.ي):"
                       FontSize="12" Foreground="#7F8C8D"
                       VerticalAlignment="Center"
                       FontFamily="Segoe UI" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                     Width="100" Height="32"
                     HorizontalAlignment="Left"
                     FontSize="13" Padding="8,0"
                     VerticalContentAlignment="Center"
                     BorderBrush="#DDE1E7" BorderThickness="1.5"
                     FontFamily="Segoe UI"
                     Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- التوصيل -->
                    <Grid Margin="0,4"
              Visibility="{Binding IsDelivery, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="التوصيل:"
                       FontSize="13" Foreground="#555"
                       FontFamily="Segoe UI" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" FontSize="13"
                       Foreground="#2C3E50" FontFamily="Segoe UI">
                <Run Text="{Binding DeliveryCost, StringFormat='{}{0:N0}'}"/>
                <Run Text=" ر.ي"/>
                        </TextBlock>
                    </Grid>

                    <Separator Background="#F0F2F5" Margin="0,10"/>

                    <!-- الإجمالي -->
                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="الإجمالي:"
                       FontSize="16" FontWeight="Bold"
                       Foreground="#1E3A5F" FontFamily="Segoe UI"
                       Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" FontSize="18"
                       FontWeight="Bold" Foreground="#E67E22"
                       FontFamily="Segoe UI">
                <Run Text="{Binding TotalAmount, StringFormat='{}{0:N0}'}"/>
                <Run Text=" ر.ي" FontSize="13" Foreground="#7F8C8D"/>
                        </TextBlock>
                    </Grid>

                    <!-- المتبقي -->
                    <Grid Margin="0,4"
              Visibility="{Binding RemainingAmount, Converter={StaticResource DecimalToBool}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="المتبقي:"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#E74C3C" FontFamily="Segoe UI"
                       Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" FontSize="14"
                       FontWeight="Bold" Foreground="#E74C3C"
                       FontFamily="Segoe UI">
                <Run Text="{Binding RemainingAmount, StringFormat='{}{0:N0}'}"/>
                <Run Text=" ر.ي"/>
                        </TextBlock>
                    </Grid>

                    <!-- عدد المنتجات -->
                    <Border Background="#F8F9FA" CornerRadius="8"
                Padding="12,8" Margin="0,12,0,0">
                        <TextBlock FontSize="12" Foreground="#555" FontFamily="Segoe UI">
                <Run Text="عدد المنتجات:"/>
                <Run Text="{Binding OrderItems.Count, Mode=OneWay}" FontWeight="Bold"/>
                        </TextBlock>
                    </Border>

                    <!-- رسالة الخطأ -->
                    <Border Background="#FDEDEC" CornerRadius="8"
                Padding="12,8" Margin="0,10,0,0"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="12" Foreground="#E74C3C"
                       FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </Border>

                    <!-- رسالة النجاح -->
                    <Border Background="#EAFAF1" CornerRadius="8"
                Padding="12,8" Margin="0,10,0,0"
                Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding SuccessMessage}"
                       FontSize="12" Foreground="#27AE60"
                       FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
            <!-- أزرار الحفظ والمسح -->
            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <Button
                    Content="💾 حفظ الطلب وإصدار الفاتورة"
                    Command="{Binding SaveOrderCommand}"
                    Height="48"
                    FontSize="14"
                    FontWeight="Bold"
                    FontFamily="Segoe UI"
                    Background="#1E3A5F"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,0,8"/>

                <Button
                    Content="🗑 مسح النموذج"
                    Command="{Binding ClearFormCommand}"
                    Height="38"
                    FontSize="13"
                    FontFamily="Segoe UI"
                    Background="#F0F2F5"
                    Foreground="#7F8C8D"
                    BorderThickness="1"
                    BorderBrush="#DDE1E7"
                    Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
