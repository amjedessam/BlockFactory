<UserControl
    x:Class="BlockFactory.Desktop.Views.Orders.NewOrderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BlockFactory.Desktop.Converters"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ErpBrushCard}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource ErpBrushNavSidebar}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource ErpBrushFieldLabel}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox" BasedOn="{StaticResource ErpFormTextBox}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="OrderCombo" TargetType="ComboBox" BasedOn="{StaticResource ErpFormComboBox}">
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource ErpPrimaryButton}">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- العمود الأيمن — تفاصيل الطلب -->
            <ColumnDefinition Width="*"/>
            <!-- العمود الأيسر — الإجماليات -->
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════ -->
        <!-- العمود الأيمن                             -->
        <!-- ══════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      Margin="0,0,14,0">
            <StackPanel>

                <!-- ─── بيانات العميل ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="👤 بيانات العميل"
                                   Style="{StaticResource SectionTitle}"/>

                        <TextBlock Text="ابحث عن العميل"
                                   Style="{StaticResource FieldLabel}"/>

                        <!-- حقل البحث مع Dropdown -->
                        <Grid>
                                <TextBox
                                Style="{StaticResource InputBox}"
                                TabIndex="1"
                                ToolTip="ابحث بجزء من الاسم ثم اضغط على العميل من القائمة. عند الحفظ يُختار تلقائياً إن وُجد عميل واحد فقط يطابق البحث."
                                Text="{Binding CustomerSearch,
                                    UpdateSourceTrigger=PropertyChanged}"
                                x:Name="CustomerSearchBox"/>

                            <!-- نتائج البحث -->
                            <Popup
                                IsOpen="{Binding CustomerResults.Count,
                                    Mode=OneWay,
                                    Converter={StaticResource CountToBool}}"
                                PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                                Placement="Bottom"
                                Width="{Binding ActualWidth,
                                    ElementName=CustomerSearchBox}"
                                StaysOpen="False">
                                <Border Background="{StaticResource ErpBrushCard}"
                                        BorderBrush="{StaticResource ErpBrushBorderInput}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000"
                                            Opacity="0.1"
                                            BlurRadius="10"
                                            ShadowDepth="3"/>
                                    </Border.Effect>
                                    <ListBox
                                        ItemsSource="{Binding CustomerResults}"
                                        SelectedItem="{Binding SelectedCustomer}"
                                        BorderThickness="0"
                                        MaxHeight="200"
                                        FontFamily="Segoe UI">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="10,6">
                                                    <TextBlock
                                                        Text="{Binding FullName}"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource ErpBrushTextPrimary}"/>
                                                    <StackPanel
                                                        Orientation="Horizontal">
                                                        <TextBlock
                                                            Text="{Binding Phone}"
                                                            FontSize="11"
                                                            Foreground="{StaticResource ErpBrushTextSecondary}"
                                                            Margin="0,0,10,0"/>
                                                        <TextBlock
                                                            FontSize="11"
                                                            Foreground="#E74C3C"
                                                            Visibility="{Binding TotalDebt,
                                                                Converter={StaticResource DecimalToBool}}">
                                                            <Run Text="دين:"/>
                                                            <Run Text="{Binding TotalDebt,
                                                                StringFormat='{}{0:N0} ر.ي'}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- تحذير الدين -->
                        <TextBlock
                            Text="{Binding CustomerDebtText}"
                            FontSize="12"
                            FontFamily="Segoe UI"
                            Margin="0,6,0,0"
                            Foreground="#E74C3C"
                            Visibility="{Binding HasSelectedCustomer,
                                Converter={StaticResource BoolToVisibility}}"/>

                        <!-- تاريخ الطلب -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="تاريخ الطلب"
                                           Style="{StaticResource FieldLabel}"/>
                                <DatePicker
                                    SelectedDate="{Binding OrderDate}"
                                    TabIndex="2"
                                    Height="38"
                                    FontFamily="Segoe UI"/>
                            </StackPanel>

                            <!-- تاريخ الاستحقاق -->
                            <StackPanel Grid.Column="1"
                                        Visibility="{Binding ShowDueDate,
                                            Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="تاريخ الاستحقاق"
                                           Style="{StaticResource FieldLabel}"/>
                                <DatePicker
                                    SelectedDate="{Binding DueDate}"
                                    TabIndex="3"
                                    Height="38"
                                    FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── طريقة الدفع ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="💳 طريقة الدفع"
                                   Style="{StaticResource SectionTitle}"/>

                        <!-- أزرار طريقة الدفع -->
                        <ItemsControl ItemsSource="{Binding PaymentTypes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton
                                        Content="{Binding Name}"
                                        GroupName="PaymentType"
                                        Margin="0,0,8,0"
                                        FontFamily="Segoe UI"
                                        FontSize="13"
                                        IsChecked="{Binding IsSelected,
                                            Mode=OneWay}"
                                        Command="{Binding DataContext.SelectPaymentTypeCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Value}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- تفاصيل التحويل الإلكتروني -->
                        <Grid Margin="0,12,0,0"
                              Visibility="{Binding ShowWallet,
                                  Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="المحفظة"
                                           Style="{StaticResource FieldLabel}"/>
                                <ComboBox
                                    Style="{StaticResource OrderCombo}"
                                    ItemsSource="{Binding WalletOptions}"
                                    SelectedItem="{Binding SelectedWallet}"
                                    Height="38"
                                    FontFamily="Segoe UI"
                                    FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="رقم العملية"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox
                                    Style="{StaticResource InputBox}"
                                    Text="{Binding TransactionReference,
                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <!-- الدفعة الأولى للآجل/المختلط -->
                        <StackPanel
                            Margin="0,12,0,0"
                            Visibility="{Binding ShowInitialPayment,
                                Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="الدفعة الأولى (ر.ي)"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox
                                Style="{StaticResource InputBox}"
                                Width="200"
                                HorizontalAlignment="Right"
                                Text="{Binding InitialPayment,
                                    UpdateSourceTrigger=PropertyChanged,
                                    StringFormat='{}{0:N0}'}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── بيانات الرهن ─── -->
                <Border Style="{StaticResource SectionCard}"
                        Visibility="{Binding IsPledge,
                            Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="🔒 بيانات الرهن"
                                   Style="{StaticResource SectionTitle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="نوع الرهن"
                                           Style="{StaticResource FieldLabel}"/>
                                <ComboBox
                                    Style="{StaticResource OrderCombo}"
                                    ItemsSource="{Binding PledgeTypes}"
                                    SelectedValuePath="Value"
                                    DisplayMemberPath="Name"
                                    SelectedValue="{Binding SelectedPledgeType}"
                                    Height="38"
                                    FontFamily="Segoe UI"
                                    FontSize="13"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="تاريخ السداد"
                                           Style="{StaticResource FieldLabel}"/>
                                <DatePicker
                                    SelectedDate="{Binding PledgeDueDate}"
                                    Height="38"
                                    FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="وصف الرهن"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,12,0,5"/>
                        <TextBox
                            Style="{StaticResource InputBox}"
                            Text="{Binding PledgeDescription,
                                UpdateSourceTrigger=PropertyChanged}"
                            Height="60"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalContentAlignment="Top"
                            Padding="10"/>
                    </StackPanel>
                </Border>

                <!-- ─── إضافة منتجات ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="🧱 المنتجات"
                                   Style="{StaticResource SectionTitle}"/>

                        <!-- صف إضافة منتج -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- اختيار المنتج -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="المنتج"
                                           Style="{StaticResource FieldLabel}"/>
                                <ComboBox
                                    Style="{StaticResource OrderCombo}"
                                    ItemsSource="{Binding AvailableProducts}"
                                    SelectedItem="{Binding SelectedProduct}"
                                    DisplayMemberPath="Name"
                                    Height="38"
                                    FontFamily="Segoe UI"
                                    FontSize="13"/>
                            </StackPanel>

                            <!-- الكمية -->
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="الكمية"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox
                                    Style="{StaticResource InputBox}"
                                    Text="{Binding NewItemQuantity,
                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <!-- السعر -->
                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock
                                    Text="{Binding NewItemPriceRange,
                                        FallbackValue='السعر (ر.ي)'}"
                                    Style="{StaticResource FieldLabel}"/>
                                <TextBox
                                    Style="{StaticResource InputBox}"
                                    Text="{Binding NewItemPrice,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    IsReadOnly="{Binding CanChangePrice,
                                        Converter={StaticResource InverseBool}}">
                                    <TextBox.Background>
                                        <SolidColorBrush
                                            Color="{Binding IsPriceValid,
                                                Converter={StaticResource BoolToColorConverter},
                                                ConverterParameter='White|#FDEDEC'}"/>
                                    </TextBox.Background>
                                </TextBox>
                            </StackPanel>

                            <!-- زر الإضافة -->
                            <Button Grid.Column="3"
                                    Style="{StaticResource ActionBtn}"
                                    TabIndex="10"
                                    Content="➕ إضافة"
                                    Command="{Binding AddItemCommand}"
                                    Background="#E67E22"
                                    Foreground="White"
                                    VerticalAlignment="Bottom"/>
                        </Grid>

                        <!-- جدول المنتجات المضافة -->
                        <DataGrid
                            ItemsSource="{Binding OrderItems}"
                            AutoGenerateColumns="False"
                            IsReadOnly="False"
                            CanUserAddRows="False"
                            Margin="0,12,0,0"
                            MinHeight="120"
                            RowHeight="40">

                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Header="المنتج"
                                    Binding="{Binding ProductName}"
                                    IsReadOnly="True"
                                    Width="*"/>

                                <DataGridTextColumn
                                    Header="المخزون"
                                    Binding="{Binding AvailableStock}"
                                    IsReadOnly="True"
                                    Width="80"/>

                                <DataGridTextColumn
                                    Header="الكمية"
                                    Binding="{Binding Quantity,
                                        UpdateSourceTrigger=PropertyChanged}"
                                    Width="80"/>

                                <DataGridTemplateColumn Header="السعر" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox
                                                Text="{Binding UnitPrice,
                                                    UpdateSourceTrigger=PropertyChanged,
                                                    StringFormat=N0}"
                                                BorderThickness="0"
                                                Padding="4,0"
                                                VerticalContentAlignment="Center"
                                                Background="Transparent"
                                                IsReadOnly="{Binding DataContext.CanChangePrice,
                                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                                    Converter={StaticResource InverseBool}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn
                                    Header="الإجمالي"
                                    Binding="{Binding TotalPrice,
                                        StringFormat='{}{0:N0} ر.ي'}"
                                    IsReadOnly="True"
                                    Width="120"/>

                                <!-- زر الحذف -->
                                <DataGridTemplateColumn Width="50">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑"
                                                    FontSize="14"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Command="{Binding DataContext.RemoveItemCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ─── طريقة التوصيل ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="🚛 التوصيل"
                                   Style="{StaticResource SectionTitle}"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,12">
                            <RadioButton
                                Content="استلام من المصنع"
                                GroupName="Delivery"
                                IsChecked="{Binding SelectedDeliveryType,
                                    Converter={StaticResource EnumBoolConverter},
                                    ConverterParameter='Pickup'}"
                                FontFamily="Segoe UI"
                                FontSize="13"
                                Margin="0,0,20,0"/>

                            <RadioButton
                                Content="توصيل للعميل"
                                GroupName="Delivery"
                                IsChecked="{Binding SelectedDeliveryType,
                                    Converter={StaticResource EnumBoolConverter},
                                    ConverterParameter='Delivery'}"
                                FontFamily="Segoe UI"
                                FontSize="13"/>
                        </StackPanel>

                        <!-- تكلفة التوصيل -->
                        <StackPanel
                            Orientation="Horizontal"
                            Visibility="{Binding IsDelivery,
                                Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="تكلفة التوصيل (ر.ي):"
                                       Style="{StaticResource FieldLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <TextBox
                                Style="{StaticResource InputBox}"
                                Width="150"
                                Text="{Binding DeliveryCost,
                                    UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── ملاحظات ─── -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="📝 ملاحظات"
                                   Style="{StaticResource SectionTitle}"/>
                        <TextBox
                            Text="{Binding Notes,
                                UpdateSourceTrigger=PropertyChanged}"
                            Height="70"
                            TextWrapping="Wrap"
                            AcceptsReturn="True"
                            VerticalContentAlignment="Top"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Padding="10"
                            BorderBrush="{StaticResource ErpBrushBorderInput}"
                            BorderThickness="1.5"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════════════════════════════ -->
        <!-- العمود الأيسر — الإجماليات والحفظ         -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- بطاقة الإجماليات -->
            <Border Grid.Row="0"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="📋 ملخص الطلب"
                               Style="{StaticResource SectionTitle}"/>

                    <!-- عميل -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="العميل:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="{Binding SelectedCustomer.FullName,
                                       TargetNullValue='—',
                                       FallbackValue='—'}"
                                   HorizontalAlignment="Left"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource ErpBrushTextPrimary}"
                                   FontFamily="Segoe UI"/>
                    </Grid>

                    <Separator Background="{StaticResource ErpBrushPageBg}" Margin="0,8"/>

                    <!-- الحسابات -->
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="المجموع الفرعي:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="13"
                                   Foreground="#555"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource ErpBrushTextPrimary}"
                                   FontFamily="Segoe UI">
                            <Run Text="{Binding SubTotal,
                                StringFormat='{}{0:N0}'}"/>
                            <Run Text=" ر.ي"/>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,4"
                          Visibility="{Binding Discount,
                              Converter={StaticResource DecimalToBool}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="الخصم:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="13"
                                   Foreground="#E74C3C"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#E74C3C"
                                   FontFamily="Segoe UI">
                            <Run Text="-"/>
                            <Run Text="{Binding Discount,
                                StringFormat='{}{0:N0}'}"/>
                            <Run Text=" ر.ي"/>
                        </TextBlock>
                    </Grid>

                    <!-- خصم -->
                    <Grid Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="خصم (ر.ي):"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"/>
                        <TextBox Grid.Column="1"
                                 HorizontalAlignment="Left"
                                 Width="100"
                                 Style="{StaticResource InputBox}"
                                 TabIndex="20"
                                 Text="{Binding Discount,
                                     UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding CanChangePrice,
                                     Converter={StaticResource InverseBool}}"/>
                    </Grid>

                    <Grid Margin="0,4"
                          Visibility="{Binding IsDelivery,
                              Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="التوصيل:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="13"
                                   Foreground="#555"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource ErpBrushTextPrimary}"
                                   FontFamily="Segoe UI">
                            <Run Text="{Binding DeliveryCost,
                                StringFormat='{}{0:N0}'}"/>
                            <Run Text=" ر.ي"/>
                        </TextBlock>
                    </Grid>

                    <Separator Background="{StaticResource ErpBrushPageBg}" Margin="0,10"/>

                    <!-- الإجمالي -->
                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="الإجمالي:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#E67E22"
                                   FontFamily="Segoe UI">
                            <Run Text="{Binding TotalAmount,
                                StringFormat='{}{0:N0}'}"/>
                            <Run Text=" ر.ي"
                                 FontSize="13"
                                 Foreground="{StaticResource ErpBrushTextSecondary}"/>
                        </TextBlock>
                    </Grid>

                    <!-- المتبقي -->
                    <Grid Margin="0,4"
                          Visibility="{Binding RemainingAmount,
                              Converter={StaticResource DecimalToBool}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="المتبقي:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#E74C3C"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#E74C3C"
                                   FontFamily="Segoe UI">
                            <Run Text="{Binding RemainingAmount,
                                StringFormat='{}{0:N0}'}"/>
                            <Run Text=" ر.ي"/>
                        </TextBlock>
                    </Grid>

                    <!-- عدد العناصر -->
                    <Border Background="#F8F9FA"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,12,0,0">
                        <TextBlock FontSize="12"
                                   Foreground="#555"
                                   FontFamily="Segoe UI">
                            <Run Text="عدد المنتجات:"/>
                            <Run Text="{Binding OrderItems.Count,
                                       Mode=OneWay}"
                                 FontWeight="Bold"/>
                        </TextBlock>
                    </Border>

                    <!-- رسائل الحالة -->
                    <Border Background="#FDEDEC"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,10,0,0"
                            Visibility="{Binding HasError,
                                Converter={StaticResource BoolToVisibility}}">
                        <TextBlock
                            Text="{Binding ErrorMessage}"
                            FontSize="12"
                            Foreground="#E74C3C"
                            FontFamily="Segoe UI"
                            TextWrapping="Wrap"/>
                    </Border>

                    <Border Background="#EAFAF1"
                            CornerRadius="8"
                            Padding="12,8"
                            Margin="0,10,0,0"
                            Visibility="{Binding SuccessMessage,
                                Converter={StaticResource StringToVisibility}}">
                        <TextBlock
                            Text="{Binding SuccessMessage}"
                            FontSize="12"
                            Foreground="#27AE60"
                            FontFamily="Segoe UI"
                            TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- أزرار الحفظ والمسح -->
            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <Button
                    Content="💾 حفظ الطلب وإصدار الفاتورة"
                    Command="{Binding SaveOrderCommand}"
                    Style="{StaticResource ErpPrimaryDarkButton}"
                    TabIndex="30"
                    Margin="0,0,0,8"/>

                <Button
                    Content="🗑 مسح النموذج"
                    Command="{Binding ClearFormCommand}"
                    Style="{StaticResource ErpSecondaryButton}"
                    TabIndex="31"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
