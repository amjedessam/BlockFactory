<UserControl
    x:Class="BlockFactory.Desktop.Views.Orders.OrdersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Filters -->
            <RowDefinition Height="Auto"/>
            <!-- Summary Cards -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Messages -->
        </Grid.RowDefinitions>

        <!-- ─── Toolbar ─── -->
        <Border Grid.Row="0"
                Background="{StaticResource ErpBrushCard}"
                CornerRadius="12"
                Padding="16,12"
                Margin="0,0,0,12">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.05"
                                  BlurRadius="8" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- بحث -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{StaticResource ErpBrushBorderInput}"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            Margin="0,0,8,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="🔍" FontSize="14"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Height="36"
                                     Padding="8,0"
                                     VerticalContentAlignment="Center"
                                     FontSize="13"
                                     FontFamily="Segoe UI"
                                     Background="Transparent"/>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Column="1"
                               Text="من:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               FontSize="13"
                               FontFamily="Segoe UI"/>

                    <DatePicker Grid.Column="2"
                                SelectedDate="{Binding FromDate}"
                                Height="36" Width="130"
                                Margin="0,0,8,0"
                                FontFamily="Segoe UI"/>

                    <TextBlock Grid.Column="3"
                               Text="إلى:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               FontSize="13"
                               FontFamily="Segoe UI"/>

                    <DatePicker Grid.Column="4"
                                SelectedDate="{Binding ToDate}"
                                Height="36" Width="130"
                                FontFamily="Segoe UI"/>
                </Grid>

                <!-- أزرار العمليات -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">

                    <Button Content="🔄 تحديث"
                            Command="{Binding LoadOrdersCommand}"
                            Height="36" Padding="14,0"
                            Margin="0,0,8,0"
                            Background="{StaticResource ErpBrushPageBg}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource ErpBrushBorderInput}"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"/>

                    <Button Content="💳 دفعة"
                            Command="{Binding AddPaymentCommand}"
                            Height="36" Padding="14,0"
                            Margin="0,0,8,0"
                            Background="#2980B9"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"/>

                    <Button Content="🖨️ طباعة"
                            Command="{Binding PrintInvoiceCommand}"
                            Height="36" Padding="14,0"
                            Margin="0,0,8,0"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            Cursor="Hand"/>

                    <Button Content="➕ طلب جديد"
                            Command="{Binding NewOrderCommand}"
                            Height="36" Padding="16,0"
                            Background="#E67E22"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontSize="13"
                            FontWeight="Bold"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── فلاتر الحالة ─── -->
        <Border Grid.Row="1" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Segmented Filter Bar -->
                <Border Grid.Column="0"
                        Background="{StaticResource ErpBrushCard}"
                        CornerRadius="12"
                        Padding="4"
                        BorderThickness="1"
                        BorderBrush="{StaticResource ErpBrushBorderInput}">
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.05"
                                          BlurRadius="8" ShadowDepth="1"/>
                    </Border.Effect>

                    <ListBox ItemsSource="{Binding FilterOptions}"
                             SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding"         Value="0"/>
                                <Setter Property="Margin"          Value="2,0"/>
                                <Setter Property="Background"      Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Cursor"          Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Pill"
                                                    CornerRadius="8"
                                                    Padding="16,7"
                                                    Background="Transparent">
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- نقطة الحالة -->
                                                    <Ellipse x:Name="Dot"
                                                             Width="7" Height="7"
                                                             Margin="0,0,7,0"
                                                             VerticalAlignment="Center"
                                                             Fill="#BDC3C7"
                                                             Visibility="Collapsed"/>
                                                    <TextBlock x:Name="Label"
                                                               Text="{TemplateBinding Content}"
                                                               FontSize="12.5"
                                                               FontWeight="SemiBold"
                                                               FontFamily="Segoe UI"
                                                               Foreground="#777"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Pill"
                                                            Property="Background"
                                                            Value="#1A73E8"/>
                                                    <Setter TargetName="Label"
                                                            Property="Foreground"
                                                            Value="White"/>
                                                    <Setter TargetName="Label"
                                                            Property="FontWeight"
                                                            Value="Bold"/>
                                                    <Setter TargetName="Dot"
                                                            Property="Visibility"
                                                            Value="Visible"/>
                                                    <Setter TargetName="Dot"
                                                            Property="Fill"
                                                            Value="White"/>
                                                    <Setter TargetName="Pill"
                                                            Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect
                                                                Color="#1A73E8"
                                                                Opacity="0.35"
                                                                BlurRadius="10"
                                                                ShadowDepth="0"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Pill"
                                                            Property="Background"
                                                            Value="#EEF4FD"/>
                                                    <Setter TargetName="Label"
                                                            Property="Foreground"
                                                            Value="#1A73E8"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Pill"
                                                            Property="Background"
                                                            Value="#1558C0"/>
                                                    <Setter TargetName="Label"
                                                            Property="Foreground"
                                                            Value="White"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Border>
            </Grid>
        </Border>

        <!-- ─── بطاقات الإجماليات ─── -->
        <UniformGrid Grid.Row="2" Columns="4"
                     Margin="0,0,0,12">

            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10"
                    Padding="16,10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="عدد الطلبات"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource ErpBrushTextPrimary}"
                               FontFamily="Segoe UI">
                        <Run Text="{Binding OrdersCount}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10"
                    Padding="16,10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="إجمالي المبيعات"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource ErpBrushNavSidebar}"
                               FontFamily="Segoe UI">
                        <Run Text="{Binding TotalAmount, StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12" Foreground="{StaticResource ErpBrushTextSecondary}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10"
                    Padding="16,10" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="إجمالي المحصّل"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="#27AE60"
                               FontFamily="Segoe UI">
                        <Run Text="{Binding TotalPaid, StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12" Foreground="{StaticResource ErpBrushTextSecondary}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10"
                    Padding="16,10">
                <StackPanel>
                    <TextBlock Text="إجمالي المتبقي"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock FontSize="18" FontWeight="Bold"
                               Foreground="#E74C3C"
                               FontFamily="Segoe UI">
                        <Run Text="{Binding TotalRemaining, StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12" Foreground="{StaticResource ErpBrushTextSecondary}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ─── DataGrid + لوحة الدفع ─── -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding IsPaymentFormVisible,
                    Converter={StaticResource BoolToWidth},
                    ConverterParameter='400|0'}"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12"
                    Padding="0"
                    Margin="0,0,12,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <DataGrid ItemsSource="{Binding Orders}"
                      SelectedItem="{Binding SelectedOrder}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{StaticResource ErpBrushGridLine}"
                      HeadersVisibility="Column"
                      BorderThickness="0"
                      Background="{StaticResource ErpBrushCard}"
                      RowBackground="{StaticResource ErpBrushCard}"
                      AlternatingRowBackground="{StaticResource ErpBrushRowAlt}"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      FontFamily="Segoe UI"
                      FontSize="13"
                      RowHeight="42">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="Foreground" Value="{StaticResource ErpBrushTextSecondary}"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="14,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="رقم الطلب"
                        Binding="{Binding OrderNumber}" Width="130"/>

                        <DataGridTextColumn Header="العميل"
                        Binding="{Binding CustomerName}" Width="*"/>

                        <DataGridTextColumn Header="التاريخ"
                        Binding="{Binding OrderDate, StringFormat='dd/MM/yyyy'}"
                        Width="100"/>

                        <DataGridTextColumn Header="الاستحقاق"
                        Binding="{Binding DueDate, StringFormat='dd/MM/yyyy'}"
                        Width="100"/>

                        <DataGridTextColumn Header="الإجمالي"
                        Binding="{Binding TotalAmount, StringFormat='{}{0:N0} ر.ي'}"
                        Width="120"/>

                        <DataGridTextColumn Header="المحصّل"
                        Binding="{Binding PaidAmount, StringFormat='{}{0:N0} ر.ي'}"
                        Width="120"/>

                        <DataGridTextColumn Header="المتبقي"
                        Binding="{Binding RemainingAmount, StringFormat='{}{0:N0} ر.ي'}"
                        Width="120"/>

                        <DataGridTextColumn Header="الدفع"
                        Binding="{Binding PaymentType}" Width="80"/>

                        <!-- حالة الدفع ملونة -->
                        <DataGridTemplateColumn Header="الحالة" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,3"
                                        HorizontalAlignment="Center"
                                        Margin="4,6">
                                        <Border.Background>
                                            <SolidColorBrush
                                            Color="{Binding PaymentStatusColor}"
                                            Opacity="0.15"/>
                                        </Border.Background>
                                        <TextBlock
                                        Text="{Binding PaymentStatus}"
                                        FontSize="11" FontWeight="SemiBold"
                                        Foreground="{Binding PaymentStatusColor}"
                                        HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- أيقونة الرهن -->
                        <DataGridTemplateColumn Header="رهن" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                    Text="🔒"
                                    FontSize="14"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding HasPledge,
                                        Converter={StaticResource BoolToVisibility}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- أيقونة متأخر -->
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                    Text="⚠️"
                                    FontSize="14"
                                    HorizontalAlignment="Center"
                                    ToolTip="طلب متأخر عن السداد"
                                    Visibility="{Binding IsOverdue,
                                        Converter={StaticResource BoolToVisibility}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- لوحة تسجيل دفعة -->
            <Border Grid.Column="1"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12" Padding="16"
                    Visibility="{Binding IsPaymentFormVisible,
                        Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text=" تسجيل دفعة"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SelectedOrder.OrderNumber,
                            StringFormat='الطلب: {0}'}"
                                   FontSize="13"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI" Margin="0,0,0,8"/>
                        <TextBlock FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   Margin="0,0,0,12">
                            <Run Text="المتبقي: "/>
                            <Run Text="{Binding SelectedOrder.RemainingAmount,
                                StringFormat='{}{0:N0} ر.ي'}"
                                 FontWeight="SemiBold"/>
                        </TextBlock>

                        <TextBlock Text="المبلغ (ر.ي)" FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding PayAmount,
                            UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Padding="10,0"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Margin="0,0,0,12"
                                 BorderBrush="{StaticResource ErpBrushBorderInput}"
                                 BorderThickness="1.5"/>

                        <CheckBox Content="دفع عبر محفظة إلكترونية (سبأفون / وان كاش)"
                                  IsChecked="{Binding PayAsElectronic}"
                                  FontFamily="Segoe UI" FontSize="13"
                                  Margin="0,0,0,8"/>

                        <TextBlock Text="المحفظة" FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding WalletOptions}"
                                  SelectedItem="{Binding PayWallet}"
                                  Height="36" FontFamily="Segoe UI" FontSize="13"
                                  Margin="0,0,0,12"
                                  IsEnabled="{Binding PayAsElectronic}"/>

                        <TextBlock Text="رقم العملية / المرجع"
                                   FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding PayReference,
                            UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" Padding="10,0"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Margin="0,0,0,12"
                                 BorderBrush="{StaticResource ErpBrushBorderInput}"
                                 BorderThickness="1.5"/>

                        <TextBlock Text="ملاحظات (اختياري)" FontSize="12"
                                   Foreground="{StaticResource ErpBrushTextSecondary}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding PayNotes,
                            UpdateSourceTrigger=PropertyChanged}"
                                 Height="56" Padding="10,8"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 FontFamily="Segoe UI" FontSize="13"
                                 Margin="0,0,0,16"
                                 BorderBrush="{StaticResource ErpBrushBorderInput}"
                                 BorderThickness="1.5"/>

                        <Button Content="💾 حفظ الدفعة"
                                Command="{Binding SavePaymentCommand}"
                                Height="40"
                                Background="#27AE60"
                                Foreground="White"
                                BorderThickness="0"
                                FontFamily="Segoe UI" FontSize="13"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Margin="0,0,0,8"/>

                        <Button Content="إلغاء"
                                Command="{Binding CancelPaymentCommand}"
                                Height="36"
                                Background="{StaticResource ErpBrushPageBg}"
                                Foreground="{StaticResource ErpBrushTextSecondary}"
                                BorderBrush="{StaticResource ErpBrushBorderInput}"
                                BorderThickness="1"
                                FontFamily="Segoe UI" FontSize="13"
                                Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ─── رسائل الحالة ─── -->
        <StackPanel Grid.Row="4" Margin="0,10,0,0">
            <Border Padding="12,8"
                    CornerRadius="8"
                    Visibility="{Binding HasError,
                        Converter={StaticResource BoolToVisibility}}"
                    Background="#FDEDEC">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E74C3C"
                           FontFamily="Segoe UI"
                           FontSize="13"/>
            </Border>
            <Border Padding="12,8" CornerRadius="8" Margin="0,8,0,0"
                    Visibility="{Binding SuccessMessage,
                        Converter={StaticResource StringToVisibility}}"
                    Background="#EAFAF1">
                <TextBlock Text="{Binding SuccessMessage}"
                           Foreground="#27AE60"
                           FontFamily="Segoe UI"
                           FontSize="13"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
