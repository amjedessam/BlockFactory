<UserControl
    x:Class="BlockFactory.Desktop.Views.Dashboard.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <!-- ── ألوان KPI ── -->
        <SolidColorBrush x:Key="KpiBlue"   Color="#1A73E8"/>
        <SolidColorBrush x:Key="KpiOrange" Color="#F4811F"/>
        <SolidColorBrush x:Key="KpiRed"    Color="#E53935"/>
        <SolidColorBrush x:Key="KpiGreen"  Color="#1E8449"/>
        <SolidColorBrush x:Key="KpiPurple" Color="#6D28D9"/>

        <!-- ── KPI Card Style ── -->
        <Style x:Key="KpiCard" TargetType="Border">
            <Setter Property="Background"    Value="{StaticResource ErpBrushCard}"/>
            <Setter Property="CornerRadius"  Value="14"/>
            <Setter Property="Padding"       Value="20,18"/>
            <Setter Property="Margin"        Value="0,0,14,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.07"
                                      BlurRadius="16" ShadowDepth="2"
                                      Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Alert Card Style ── -->
        <Style x:Key="AlertCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding"      Value="14,12"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" Opacity="0.04"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Section Card Style ── -->
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background"   Value="{StaticResource ErpBrushCard}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.07"
                                      BlurRadius="16" ShadowDepth="2"
                                      Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="4,0,4,24">

            <!-- ════════════════════════════════════════ -->
            <!-- 1. HEADER BANNER                        -->
            <!-- ════════════════════════════════════════ -->
            <Border CornerRadius="16" Margin="0,0,0,20" Padding="28,22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A2E4A" Offset="0"/>
                        <GradientStop Color="#1A4D7A" Offset="0.6"/>
                        <GradientStop Color="#1E6FA5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#1A2E4A" Opacity="0.25"
                                      BlurRadius="20" ShadowDepth="4"
                                      Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- اليمين: اسم المستخدم والتاريخ -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding WelcomeMessage}"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="White"
                                   FontFamily="Segoe UI"/>
                        <TextBlock Text="{Binding TodayDate}"
                                   FontSize="13" Foreground="#B0C4DE"
                                   FontFamily="Segoe UI" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- اليسار: آخر تحديث -->
                    <Border Grid.Column="1"
                            Background="#1F3F60" CornerRadius="10"
                            Padding="14,8" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text=""
                                       FontSize="10" Foreground="#90A8C0"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding LastUpdated,
                                           StringFormat='{}{0}'}"
                                       FontSize="12" Foreground="#B0C4DE"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════ -->
            <!-- 2. ALERTS                               -->
            <!-- ════════════════════════════════════════ -->
            <ItemsControl ItemsSource="{Binding Alerts}"
                          Margin="0,0,0,18"
                          Visibility="{Binding HasAlerts,
                              Converter={StaticResource BoolToVisibility}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource AlertCard}"
                                Background="{StaticResource ErpBrushCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="5"/>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- شريط اللون الجانبي -->
                                <Border Grid.Column="0"
                                        CornerRadius="4,0,0,4"
                                        Margin="-14,-12,0,-12">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Color}"/>
                                    </Border.Background>
                                </Border>

                                <!-- أيقونة -->
                                <Border Grid.Column="1"
                                        Width="34" Height="34"
                                        CornerRadius="8"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Color}"
                                                         Opacity="0.12"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- النص -->
                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="13" FontWeight="Bold"
                                               FontFamily="Segoe UI">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding Color}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Message}"
                                               FontSize="11.5"
                                               Foreground="{StaticResource ErpBrushTextSecondary}"
                                               FontFamily="Segoe UI"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ════════════════════════════════════════ -->
            <!-- 3. KPI CARDS — صف أول                  -->
            <!-- ════════════════════════════════════════ -->
            <UniformGrid Columns="4" Margin="0,0,0,16">

                <!-- مبيعات اليوم -->
                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- رأس الكارد -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="مبيعات اليوم"
                                       FontSize="12" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"/>
                        </Grid>

                        <!-- القيمة -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <TextBlock FontSize="26" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource KpiBlue}">
                                <Run Text="{Binding TodaySales,
                                    StringFormat='{}{0:N0}'}"/>
                            </TextBlock>
                            <TextBlock Text=" ر.ي" FontSize="13"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"
                                       VerticalAlignment="Bottom"
                                       Margin="4,0,0,3"/>
                        </StackPanel>

                        <!-- الذيل -->
                        <Border Grid.Row="4" Background="#EBF5FB"
                                CornerRadius="6" Padding="8,4">
                            <TextBlock FontSize="11" FontFamily="Segoe UI"
                                       Foreground="#1A73E8">
                                <Run Text=""/>
                                <Run Text="{Binding TodayOrdersCount}"/>
                                <Run Text=" طلب اليوم"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>

                <!-- مبيعات الشهر -->
                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="مبيعات الشهر"
                                       FontSize="12" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"/>
                        </Grid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <TextBlock FontSize="26" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource KpiBlue}">
                                <Run Text="{Binding MonthSales,
                                    StringFormat='{}{0:N0}'}"/>
                            </TextBlock>
                            <TextBlock Text=" ر.ي" FontSize="13"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"
                                       VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                        </StackPanel>
                        <Border Grid.Row="4" Background="#FEF3E2"
                                CornerRadius="6" Padding="8,4">
                            <TextBlock FontSize="11" FontFamily="Segoe UI"
                                       Foreground="#1A73E8">
                                <Run Text=""/>
                                <Run Text="{Binding TodayProduction}"/>
                                <Run Text=" بلكة أُنتجت اليوم"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>

                <!-- ديون العملاء -->
                <Border Style="{StaticResource KpiCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ديون العملاء"
                                       FontSize="12" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"/>
                        </Grid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <TextBlock FontSize="26" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource KpiBlue}">
                                <Run Text="{Binding TotalCustomerDebt,
                                    StringFormat='{}{0:N0}'}"/>
                            </TextBlock>
                            <TextBlock Text=" ر.ي" FontSize="13"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"
                                       VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                        </StackPanel>
                        <Border Grid.Row="4" Background="#FDE8E8"
                                CornerRadius="6" Padding="8,4">
                            <TextBlock FontSize="11" FontFamily="Segoe UI"
                                       Foreground="#1A73E8">
                                <Run Text=""/>
                                <Run Text="{Binding PledgesDueSoonCount}"/>
                                <Run Text=" رهن يستحق قريباً"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>

                <!-- الصندوق النقدي -->
                <Border Style="{StaticResource KpiCard}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="الصندوق النقدي"
                                       FontSize="12" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"/>
                        </Grid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <TextBlock FontSize="26" FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource KpiBlue}">
                                <Run Text="{Binding CashBalance,
                                    StringFormat='{}{0:N0}'}"/>
                            </TextBlock>
                            <TextBlock Text=" ر.ي" FontSize="13"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"
                                       VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                        </StackPanel>
                        <Border Grid.Row="4" Background="#E4F5EC"
                                CornerRadius="6" Padding="8,4">
                            <TextBlock FontSize="11" FontFamily="Segoe UI"
                                       Foreground="#1A73E8">
                                <Run Text=""/>
                                <Run Text="{Binding TotalWalletsBalance,
                                    StringFormat='{}{0:N0}'}"/>
                                <Run Text=" ر.ي محافظ"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- ════════════════════════════════════════ -->
            <!-- 4. جدول الطلبات + الربح والمخزون       -->
            <!-- ════════════════════════════════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="260"/>
                </Grid.ColumnDefinitions>

                <!-- ── جدول آخر الطلبات ── -->
                <Border Grid.Column="0"
                        Style="{StaticResource SectionCard}"
                        Margin="0,0,14,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- عنوان الجدول -->
                        <Border Grid.Row="0" Padding="20,16"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{StaticResource ErpBrushGridLine}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <Border Width="4" CornerRadius="2"
                                            Background="{StaticResource KpiBlue}"
                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="آخر الطلبات"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource ErpBrushTextPrimary}"
                                               FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="#EBF5FB" CornerRadius="20"
                                        Padding="10,3">
                                    <TextBlock FontSize="11" Foreground="#1A73E8"
                                               FontFamily="Segoe UI">
                                        <Run Text=""/>
                                        <Run Text="{Binding TodayOrdersCount}"/>
                                        <Run Text=" اليوم"/>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- الجدول -->
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding RecentOrders}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  Background="{StaticResource ErpBrushCard}"
                                  RowBackground="{StaticResource ErpBrushCard}"
                                  AlternatingRowBackground="{StaticResource ErpBrushRowAlt}"
                                  HorizontalGridLinesBrush="{StaticResource ErpBrushGridLine}"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  FontFamily="Segoe UI"
                                  FontSize="13"
                                  RowHeight="46">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F5F7FA"/>
                                    <Setter Property="Foreground"
                                            Value="{StaticResource ErpBrushTextSecondary}"/>
                                    <Setter Property="FontSize" Value="11.5"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="14,10"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="رقم الطلب"
                                    Binding="{Binding OrderNumber}"
                                    Width="130"/>
                                <DataGridTextColumn Header="العميل"
                                    Binding="{Binding CustomerName}"
                                    Width="*"/>
                                <DataGridTextColumn Header="المبلغ"
                                    Binding="{Binding TotalAmount,
                                        StringFormat='{}{0:N0} ر.ي'}"
                                    Width="130"/>
                                <DataGridTextColumn Header="الدفع"
                                    Binding="{Binding PaymentType}"
                                    Width="85"/>

                                <DataGridTemplateColumn Header="الحالة" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="20"
                                                    Padding="10,4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="0,8">
                                                <Border.Background>
                                                    <SolidColorBrush
                                                        Color="{Binding StatusColor}"
                                                        Opacity="0.15"/>
                                                </Border.Background>
                                                <TextBlock Text="{Binding Status}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           FontFamily="Segoe UI"
                                                           Foreground="{Binding StatusColor}"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- ── عمود: الربح + المخزون ── -->
                <StackPanel Grid.Column="1">

                    <!-- صافي الربح -->
                    <Border Style="{StaticResource SectionCard}" Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- شريط علوي ملون -->
                            <Border Grid.Row="0" Height="5" CornerRadius="14,14,0,0">
                                <Border.Background>
                                    <SolidColorBrush
                                        Color="{Binding IsNetProfitPositive,
                                            Converter={StaticResource BoolToColorConverter},
                                            ConverterParameter='#1E8449|#E53935'}"/>
                                </Border.Background>
                            </Border>

                            <Border Grid.Row="1" Padding="20,16,20,4">
                                <StackPanel>
                                    <TextBlock Text="صافي ربح الشهر"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource ErpBrushTextSecondary}"
                                           FontFamily="Segoe UI"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock FontSize="28" FontWeight="Bold"
                                               FontFamily="Segoe UI">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush
                                                Color="{Binding IsNetProfitPositive,
                                                    Converter={StaticResource BoolToColorConverter},
                                                    ConverterParameter='#1E8449|#E53935'}"/>
                                            </TextBlock.Foreground>
                                        <Run Text="{Binding NetProfit,
                                            StringFormat='{}{0:N0}'}"/>
                                        </TextBlock>
                                        <TextBlock Text=" ر.ي" FontSize="13"
                                               FontFamily="Segoe UI"
                                               Foreground="{StaticResource ErpBrushTextSecondary}"
                                               VerticalAlignment="Bottom"
                                               Margin="4,0,0,4"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Margin="20,0,20,16"
                                    CornerRadius="8" Padding="12,7">
                                <Border.Background>
                                    <SolidColorBrush
                                        Color="{Binding IsNetProfitPositive,
                                            Converter={StaticResource BoolToColorConverter},
                                            ConverterParameter='#E4F5EC|#FDE8E8'}"/>
                                </Border.Background>
                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                           FontFamily="Segoe UI"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush
                                            Color="{Binding IsNetProfitPositive,
                                                Converter={StaticResource BoolToColorConverter},
                                                ConverterParameter='#1E8449|#E53935'}"/>
                                    </TextBlock.Foreground>
                                    <Run Text="{Binding IsNetProfitPositive,
                                        Converter={StaticResource BoolToTextConverter},
                                        ConverterParameter='✅ ربح|❌ خسارة'}"/>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- تنبيهات المخزون -->
                    <Border Style="{StaticResource SectionCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Height="5"
                                    CornerRadius="14,14,0,0"
                                    Background="#F4811F"/>

                            <Border Grid.Row="1" Padding="20,16,20,4">
                                <StackPanel>
                                    <TextBlock Text="تنبيهات المخزون"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource ErpBrushTextSecondary}"
                                           FontFamily="Segoe UI"/>
                                    <TextBlock Margin="0,10,0,0"
                                           FontSize="36" FontWeight="Bold"
                                           FontFamily="Segoe UI"
                                           Foreground="#F4811F">
                                    <Run Text="{Binding LowStockCount}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Margin="20,0,20,16"
                                    Background="#FEF3E2" CornerRadius="8"
                                    Padding="12,7">
                                <TextBlock Text="منتج أو مادة خام بحاجة لتعبئة"
                                           FontSize="11" Foreground="#E67E22"
                                           FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
