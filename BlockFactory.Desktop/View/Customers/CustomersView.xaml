<UserControl
    x:Class="BlockFactory.Desktop.Views.Customers.CustomersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- القائمة الرئيسية -->
            <ColumnDefinition Width="*"/>
            <!-- نموذج الإضافة/التعديل -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════ -->
        <!-- القائمة الرئيسية                         -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── Toolbar ─── -->
            <Border Grid.Row="0"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12"
                    Padding="16,12"
                    Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- بحث -->
                    <Border Grid.Column="0"
                            BorderBrush="{StaticResource ErpBrushBorderInput}"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            Width="280"
                            HorizontalAlignment="Right">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="🔍" FontSize="14"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding SearchText,
                                         UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"
                                     Height="36"
                                     Padding="8,0"
                                     VerticalContentAlignment="Center"
                                     FontSize="13"
                                     FontFamily="Segoe UI"
                                     Background="Transparent"/>
                        </Grid>
                    </Border>

                    <!-- أزرار -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left">

                        <Button Content="🔄 تحديث"
                                Command="{Binding LoadCommand}"
                                Height="36" Padding="12,0"
                                Margin="0,0,8,0"
                                Background="{StaticResource ErpBrushPageBg}"
                                BorderThickness="1"
                                BorderBrush="{StaticResource ErpBrushBorderInput}"
                                FontFamily="Segoe UI"
                                FontSize="13"
                                Cursor="Hand"/>

                        <Button Content="✏️ تعديل"
                                Command="{Binding ShowEditFormCommand}"
                                Height="36" Padding="12,0"
                                Margin="0,0,8,0"
                                Background="#2980B9"
                                Foreground="White"
                                BorderThickness="0"
                                FontFamily="Segoe UI"
                                FontSize="13"
                                Cursor="Hand"/>

                        <Button Content="🗑 حذف"
                                Command="{Binding DeleteCommand}"
                                Visibility="{Binding CanDeleteCustomer,
                                    Converter={StaticResource BoolToVisibility}}"
                                Height="36" Padding="12,0"
                                Margin="0,0,8,0"
                                Background="#E74C3C"
                                Foreground="White"
                                BorderThickness="0"
                                FontFamily="Segoe UI"
                                FontSize="13"
                                Cursor="Hand"/>

                        <Button Content="➕ عميل جديد"
                                Command="{Binding ShowAddFormCommand}"
                                Height="36" Padding="16,0"
                                Background="#E67E22"
                                Foreground="White"
                                BorderThickness="0"
                                FontFamily="Segoe UI"
                                FontSize="13"
                                FontWeight="Bold"
                                Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── فلاتر ─── -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,12">
                <ItemsControl ItemsSource="{Binding FilterOptions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,8,0"
                                    CornerRadius="20"
                                    Padding="14,6"
                                    Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"
                                                Value="{StaticResource ErpBrushCard}"/>
                                        <Setter Property="BorderBrush"
                                                Value="{StaticResource ErpBrushBorderInput}"/>
                                        <Setter Property="BorderThickness"
                                                Value="1"/>
                                    </Style>
                                </Border.Style>
                                <TextBlock
                                    Text="{Binding}"
                                    FontSize="12"
                                    FontFamily="Segoe UI"
                                    Foreground="#555"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ─── إحصائيات ─── -->
            <UniformGrid Grid.Row="2" Columns="3"
                         Margin="0,0,0,12">
                <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10"
                        Padding="14,10" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="إجمالي العملاء"
                                   FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock
                            Text="{Binding TotalCustomers}"
                            FontSize="22" FontWeight="Bold"
                            Foreground="{StaticResource ErpBrushNavSidebar}"
                            FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10"
                        Padding="14,10" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="لديهم ديون"
                                   FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock
                            Text="{Binding CustomersWithDebt}"
                            FontSize="22" FontWeight="Bold"
                            Foreground="#E74C3C"
                            FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10"
                        Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="إجمالي الديون"
                                   FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock FontSize="18" FontWeight="Bold"
                                   Foreground="#E74C3C"
                                   FontFamily="Segoe UI">
                            <Run Text="{Binding TotalDebt,
                                StringFormat='{}{0:N0}'}"/>
                            <Run Text=" ر.ي" FontSize="12"
                                 Foreground="{StaticResource ErpBrushTextSecondary}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ─── DataGrid ─── -->
            <Border Grid.Row="3"
                    Background="{StaticResource ErpBrushCard}"
                    CornerRadius="12">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <DataGrid
                    ItemsSource="{Binding Customers}"
                    SelectedItem="{Binding SelectedCustomer}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="{StaticResource ErpBrushGridLine}"
                    HeadersVisibility="Column"
                    BorderThickness="0"
                    Background="{StaticResource ErpBrushCard}"
                    RowBackground="{StaticResource ErpBrushCard}"
                    AlternatingRowBackground="{StaticResource ErpBrushRowAlt}"
                    CanUserResizeRows="False"
                    SelectionMode="Single"
                    FontFamily="Segoe UI"
                    FontSize="13"
                    RowHeight="42">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="Foreground" Value="{StaticResource ErpBrushTextSecondary}"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="14,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="اسم العميل"
                            Binding="{Binding FullName}" Width="*"/>

                        <DataGridTextColumn Header="الهاتف"
                            Binding="{Binding Phone}" Width="120"/>

                        <DataGridTextColumn Header="عدد الطلبات"
                            Binding="{Binding TotalOrders}" Width="100"/>

                        <DataGridTextColumn Header="إجمالي المشتريات"
                            Binding="{Binding TotalPurchases,
                                StringFormat='{}{0:N0} ر.ي'}"
                            Width="140"/>

                        <!-- الدين بلون -->
                        <DataGridTemplateColumn Header="الدين" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        FontFamily="Segoe UI"
                                        VerticalAlignment="Center"
                                        Margin="14,0"
                                        Foreground="{Binding DebtStatusColor}">
                                        <Run Text="{Binding TotalDebt,
                                            StringFormat='{}{0:N0}'}"/>
                                        <Run Text=" ر.ي"/>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- أيقونة الرهن -->
                        <DataGridTemplateColumn Header="رهن" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Text="🔒" FontSize="14"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding HasActivePledge,
                                            Converter={StaticResource BoolToVisibility}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- رسائل -->
            <Border Grid.Row="4" Padding="12,8" CornerRadius="8"
                    Margin="0,8,0,0"
                    Visibility="{Binding HasError,
                        Converter={StaticResource BoolToVisibility}}"
                    Background="#FDEDEC">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#E74C3C"
                           FontFamily="Segoe UI" FontSize="13"/>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════ -->
        <!-- نموذج الإضافة / التعديل                  -->
        <!-- ══════════════════════════════════════════ -->
        <Border Grid.Column="1"
                Width="340"
                Background="{StaticResource ErpBrushCard}"
                CornerRadius="12"
                Padding="20"
                Visibility="{Binding IsFormVisible,
                    Converter={StaticResource BoolToVisibility}}">
            <Border.Effect>
                <DropShadowEffect Color="#000" Opacity="0.05"
                                  BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock
                    Text="{Binding FormTitle}"
                    FontSize="15"
                    FontWeight="Bold"
                    Foreground="{StaticResource ErpBrushNavSidebar}"
                    FontFamily="Segoe UI"
                    Margin="0,0,0,20"/>

                <!-- الاسم -->
                <TextBlock Text="الاسم الكامل *"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#555" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormName,
                             UpdateSourceTrigger=PropertyChanged}"
                         Height="38" FontSize="13"
                         FontFamily="Segoe UI"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                         BorderThickness="1.5"
                         Margin="0,0,0,14"/>

                <!-- الهاتف -->
                <TextBlock Text="رقم الهاتف"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#555" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormPhone,
                             UpdateSourceTrigger=PropertyChanged}"
                         Height="38" FontSize="13"
                         FontFamily="Segoe UI"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                         BorderThickness="1.5"
                         Margin="0,0,0,14"/>

                <!-- العنوان -->
                <TextBlock Text="العنوان"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#555" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormAddress,
                             UpdateSourceTrigger=PropertyChanged}"
                         Height="38" FontSize="13"
                         FontFamily="Segoe UI"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                         BorderThickness="1.5"
                         Margin="0,0,0,14"/>

                <!-- ملاحظات -->
                <TextBlock Text="ملاحظات"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#555" FontFamily="Segoe UI"
                           Margin="0,0,0,5"/>
                <TextBox Text="{Binding FormNotes,
                             UpdateSourceTrigger=PropertyChanged}"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalContentAlignment="Top"
                         FontSize="13"
                         FontFamily="Segoe UI"
                         Padding="10"
                         BorderBrush="{StaticResource ErpBrushBorderInput}"
                         BorderThickness="1.5"
                         Margin="0,0,0,20"/>

                <!-- رسائل -->
                <Border Background="#FDEDEC" CornerRadius="8"
                        Padding="10,6" Margin="0,0,0,10"
                        Visibility="{Binding HasError,
                            Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#E74C3C"
                               FontSize="12" FontFamily="Segoe UI"
                               TextWrapping="Wrap"/>
                </Border>

                <Border Background="#EAFAF1" CornerRadius="8"
                        Padding="10,6" Margin="0,0,0,10"
                        Visibility="{Binding SuccessMessage,
                            Converter={StaticResource StringToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}"
                               Foreground="#27AE60"
                               FontSize="12" FontFamily="Segoe UI"/>
                </Border>

                <!-- أزرار -->
                <Button Content="💾 حفظ"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ErpPrimaryDarkButton}"
                        Margin="0,0,0,8"/>

                <Button Content="إلغاء"
                        Command="{Binding CancelFormCommand}"
                        Style="{StaticResource ErpSecondaryButton}"
                        MinHeight="36"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
