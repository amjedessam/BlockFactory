<UserControl
    x:Class="BlockFactory.Desktop.Views.Inventory.InventoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">
            <TextBlock Text="المخزون"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource ErpBrushNavSidebar}" Margin="0,0,0,12"/>

            <UniformGrid Columns="2" Margin="0,0,0,16">
                <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10" Padding="16" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="أصناف المنتجات" Foreground="{StaticResource ErpBrushTextSecondary}" FontSize="12"/>
                        <TextBlock Text="{Binding ProductSkuCount}" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10" Padding="16" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="إجمالي الوحدات" Foreground="{StaticResource ErpBrushTextSecondary}" FontSize="12"/>
                        <TextBlock Text="{Binding TotalUnits}" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="منتجات منخفضة المخزون" FontWeight="SemiBold" Margin="0,8,0,6"/>
            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10" Padding="0">
                <DataGrid ItemsSource="{Binding LowStockProducts}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="36"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المنتج" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="المتاح" Binding="{Binding QuantityAvailable}" Width="80"/>
                        <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinimumThreshold}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <TextBlock Text="مواد خام منخفضة" FontWeight="SemiBold" Margin="0,16,0,6"/>
            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="10" Padding="0">
                <DataGrid ItemsSource="{Binding LowRawMaterials}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="36"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="المادة" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="المتاح" Binding="{Binding QuantityAvailable}" Width="100"/>
                        <DataGridTextColumn Header="الحد الأدنى" Binding="{Binding MinimumThreshold}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
