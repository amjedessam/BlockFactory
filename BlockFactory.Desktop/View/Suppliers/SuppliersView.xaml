<UserControl
    x:Class="BlockFactory.Desktop.Views.Suppliers.SuppliersView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    FlowDirection="RightToLeft"
    Background="{StaticResource ErpBrushPageBg}"
    Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Summary -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ─── بطاقات الملخص ─── -->
        <UniformGrid Grid.Row="0" Columns="4"
                     Margin="0,0,0,14">

            <Border Background="{StaticResource ErpBrushNavSidebar}" CornerRadius="12"
                    Padding="16,12" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="إجمالي الموردين"
                               FontSize="11" Foreground="#BDC3C7"
                               FontFamily="Segoe UI"/>
                    <TextBlock
                        Text="{Binding Summary.TotalSuppliers,
                            FallbackValue='0'}"
                        FontSize="26" FontWeight="Bold"
                        Foreground="White"
                        FontFamily="Segoe UI"
                        Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="16,12" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="إجمالي المديونية"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock FontSize="20" FontWeight="Bold"
                               Foreground="#E74C3C"
                               FontFamily="Segoe UI"
                               Margin="0,6,0,0">
                        <Run Text="{Binding Summary.TotalDebt,
                            FallbackValue='0',
                            StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12"
                             Foreground="{StaticResource ErpBrushTextSecondary}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="16,12" Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="موردون لديهم ديون"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock
                        Text="{Binding Summary.SuppliersWithDebt,
                            FallbackValue='0'}"
                        FontSize="26" FontWeight="Bold"
                        Foreground="#F39C12"
                        FontFamily="Segoe UI"
                        Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="16,12">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="مشتريات هذا الشهر"
                               FontSize="11" Foreground="{StaticResource ErpBrushTextSecondary}"
                               FontFamily="Segoe UI"/>
                    <TextBlock FontSize="20" FontWeight="Bold"
                               Foreground="#27AE60"
                               FontFamily="Segoe UI"
                               Margin="0,6,0,0">
                        <Run Text="{Binding Summary.TotalPurchasesThisMonth,
                            FallbackValue='0',
                            StringFormat='{}{0:N0}'}"/>
                        <Run Text=" ر.ي" FontSize="12"
                             Foreground="{StaticResource ErpBrushTextSecondary}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ─── المحتوى الرئيسي ─── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- قائمة الموردين -->
                <ColumnDefinition Width="2*"/>
                <!-- فواتير المورد المحدد -->
                <ColumnDefinition Width="2*"/>
                <!-- نموذج إضافة/تعديل -->
                <ColumnDefinition Width="{Binding IsSupplierFormVisible,
                    Converter={StaticResource BoolToWidth},
                    ConverterParameter='300|0'}"/>
                <!-- نموذج الدفع -->
                <ColumnDefinition Width="{Binding IsPayFormVisible,
                    Converter={StaticResource BoolToWidth},
                    ConverterParameter='280|0'}"/>
            </Grid.ColumnDefinitions>

            <!-- ══ قائمة الموردين ══ -->
            <Border Grid.Column="0"
                    Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{StaticResource ErpBrushBorder}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="🚛 الموردون"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource ErpBrushTextPrimary}"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left">
                                <Button Content="💵 دفع"
                                        Command="{Binding ShowPayFormCommand}"
                                        Height="32" Padding="10,0"
                                        Margin="0,0,6,0"
                                        Background="#27AE60"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontFamily="Segoe UI"
                                        FontSize="12"
                                        Cursor="Hand"/>
                                <Button Content="✏️ تعديل"
                                        Command="{Binding ShowEditFormCommand}"
                                        Height="32" Padding="10,0"
                                        Margin="0,0,6,0"
                                        Background="#2980B9"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontFamily="Segoe UI"
                                        FontSize="12"
                                        Cursor="Hand"/>
                                <Button Content="➕ جديد"
                                        Command="{Binding ShowAddFormCommand}"
                                        Height="32" Padding="12,0"
                                        Background="#E67E22"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontFamily="Segoe UI"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- بحث + فلتر -->
                    <StackPanel Grid.Row="1" Margin="12,8">
                        <Border BorderBrush="{StaticResource ErpBrushBorderInput}"
                                BorderThickness="1.5"
                                CornerRadius="8"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="🔍" FontSize="13"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SearchText,
                                             UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Height="34" Padding="6,0"
                                         VerticalContentAlignment="Center"
                                         FontSize="12"
                                         FontFamily="Segoe UI"
                                         Background="Transparent"/>
                            </Grid>
                        </Border>

                        <ComboBox
                            ItemsSource="{Binding FilterOptions}"
                            SelectedItem="{Binding SelectedFilter}"
                            Height="32" FontFamily="Segoe UI"
                            FontSize="12"/>
                    </StackPanel>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource ErpBrushGridLine}"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="{StaticResource ErpBrushCard}"
                              RowBackground="{StaticResource ErpBrushCard}"
                              AlternatingRowBackground="{StaticResource ErpBrushRowAlt}"
                              CanUserResizeRows="False"
                              FontFamily="Segoe UI"
                              FontSize="12"
                              RowHeight="42">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"
                                        Value="#F8F9FA"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource ErpBrushTextSecondary}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderThickness"
                                        Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <!-- النوع مع أيقونة -->
                            <DataGridTemplateColumn
                                Header="النوع" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="8,0">
                                            <TextBlock
                                                Text="{Binding TypeIcon}"
                                                FontSize="14"
                                                Margin="0,0,4,0"/>
                                            <TextBlock
                                                Text="{Binding SupplierType}"
                                                FontSize="11"
                                                Foreground="#555"
                                                FontFamily="Segoe UI"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="الاسم"
                                Binding="{Binding FullName}" Width="*"/>

                            <DataGridTextColumn Header="الهاتف"
                                Binding="{Binding Phone}" Width="100"/>

                            <!-- الدين ملون -->
                            <DataGridTemplateColumn
                                Header="الدين" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            FontWeight="SemiBold"
                                            FontSize="12"
                                            FontFamily="Segoe UI"
                                            VerticalAlignment="Center"
                                            Margin="10,0"
                                            Foreground="{Binding DebtStatusColor}">
                                            <Run Text="{Binding TotalDebt,
                                                StringFormat='{}{0:N0}'}"/>
                                            <Run Text=" ر.ي" FontSize="10"
                                                 Foreground="{StaticResource ErpBrushTextSecondary}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ══ فواتير المورد ══ -->
            <Border Grid.Column="1"
                    Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Margin="0,0,10,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{StaticResource ErpBrushBorder}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource ErpBrushTextPrimary}"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap">
                                <Run Text="🧾 فواتير "/>
                                <Run Text="{Binding SelectedSupplier.FullName,
                                    FallbackValue=''}"/>
                            </TextBlock>
                            <Button Grid.Column="1"
                                    Content="➕ فاتورة شراء جديدة"
                                    Command="{Binding ShowNewPurchaseInvoiceCommand}"
                                    Height="34" Padding="14,0"
                                    Background="#E67E22"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontFamily="Segoe UI"
                                    FontSize="12"
                                    FontWeight="Bold"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Invoices}"
                              SelectedItem="{Binding SelectedInvoice}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource ErpBrushGridLine}"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="{StaticResource ErpBrushCard}"
                              RowBackground="{StaticResource ErpBrushCard}"
                              AlternatingRowBackground="{StaticResource ErpBrushRowAlt}"
                              CanUserResizeRows="False"
                              FontFamily="Segoe UI"
                              FontSize="12"
                              RowHeight="40">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background"
                                        Value="#F8F9FA"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource ErpBrushTextSecondary}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderThickness"
                                        Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="رقم الفاتورة"
                                Binding="{Binding InvoiceNumber}"
                                Width="110"/>
                            <DataGridTextColumn Header="التاريخ"
                                Binding="{Binding InvoiceDate,
                                    StringFormat='dd/MM/yyyy'}"
                                Width="90"/>
                            <DataGridTextColumn Header="الإجمالي"
                                Binding="{Binding TotalAmount,
                                    StringFormat='{}{0:N0}'}"
                                Width="90"/>
                            <DataGridTextColumn Header="المتبقي"
                                Binding="{Binding RemainingAmount,
                                    StringFormat='{}{0:N0}'}"
                                Width="90"/>
                            <DataGridTemplateColumn
                                Header="الحالة" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="5"
                                                Padding="6,2"
                                                HorizontalAlignment="Center"
                                                Margin="4,8">
                                            <Border.Background>
                                                <SolidColorBrush
                                                    Color="{Binding StatusColor}"
                                                    Opacity="0.15"/>
                                            </Border.Background>
                                            <TextBlock
                                                Text="{Binding Status}"
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Foreground="{Binding StatusColor}"
                                                HorizontalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- نموذج فاتورة شراء -->
                    <Border Grid.Row="2"
                            Margin="0,10,0,0"
                            Padding="14"
                            CornerRadius="10"
                            Background="#FDF6EC"
                            BorderBrush="#E67E22"
                            BorderThickness="1"
                            Visibility="{Binding IsPurchaseInvoiceFormVisible,
                                Converter={StaticResource BoolToVisibility}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      MaxHeight="360">
                            <StackPanel>
                                <TextBlock Text="فاتورة شراء جديدة"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#D35400"
                                           FontFamily="Segoe UI"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="رقم الفاتورة *"
                                           FontSize="11"
                                           Foreground="{StaticResource ErpBrushTextSecondary}"/>
                                <TextBox Text="{Binding PurchaseInvoiceNumber,
                                    UpdateSourceTrigger=PropertyChanged}"
                                         Height="34" Margin="0,4,0,10"
                                         Padding="8,0"
                                         FontFamily="Segoe UI"/>

                                <TextBlock Text="نوع السداد *"
                                           FontSize="11"
                                           Foreground="{StaticResource ErpBrushTextSecondary}"/>
                                <ComboBox SelectedIndex="{Binding PurchasePaymentModeIndex,
                                    Mode=TwoWay}"
                                          Width="260"
                                          HorizontalAlignment="Left"
                                          Height="34"
                                          Margin="0,4,0,10"
                                          FontFamily="Segoe UI"
                                          FontSize="12">
                                    <ComboBoxItem Content="آجل (على الحساب)"/>
                                    <ComboBoxItem Content="دفع الآن"/>
                                </ComboBox>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="تاريخ الفاتورة"
                                                   FontSize="11"
                                                   Foreground="{StaticResource ErpBrushTextSecondary}"/>
                                        <DatePicker SelectedDate="{Binding PurchaseInvoiceDate}"
                                                    Height="34"
                                                    FontFamily="Segoe UI"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,0,0"
                                                Visibility="{Binding ShowPurchaseDueDate,
                                                    Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="تاريخ الاستحقاق"
                                                   FontSize="11"
                                                   Foreground="{StaticResource ErpBrushTextSecondary}"/>
                                        <DatePicker SelectedDate="{Binding PurchaseDueDate}"
                                                    Height="34"
                                                    FontFamily="Segoe UI"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Visibility="{Binding ShowPurchasePayNow,
                                                    Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="مبلغ الشراء المدفوع الآن (ر.ي) *"
                                                   FontSize="11"
                                                   Foreground="{StaticResource ErpBrushTextSecondary}"/>
                                        <TextBox Text="{Binding PurchasePayNowAmount,
                                            UpdateSourceTrigger=PropertyChanged}"
                                                 Height="34"
                                                 Margin="0,4,0,0"
                                                 Padding="8,0"
                                                 VerticalContentAlignment="Center"
                                                 FontFamily="Segoe UI"/>
                                        <TextBlock
                                            Text="{Binding PurchaseLinesTotal,
                                                StringFormat='إجمالي البنود: {0:N0} ر.ي'}"
                                            FontSize="10"
                                            Foreground="#7F8C8D"
                                            Margin="0,6,0,0"
                                            FontFamily="Segoe UI"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="البنود"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="#555"
                                           Margin="0,0,0,6"/>

                                <ItemsControl ItemsSource="{Binding PurchaseInvoiceLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8"
                                                    BorderBrush="{StaticResource ErpBrushBorderInput}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="المادة"
                                                               FontSize="10"
                                                               Foreground="#7F8C8D"
                                                               Margin="0,0,0,4"
                                                               FontFamily="Segoe UI"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                                               Text="الكمية"
                                                               FontSize="10"
                                                               HorizontalAlignment="Center"
                                                               Foreground="#7F8C8D"
                                                               Margin="0,0,0,4"
                                                               FontFamily="Segoe UI"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2"
                                                               Text="سعر الوحدة (ر.ي)"
                                                               FontSize="10"
                                                               HorizontalAlignment="Center"
                                                               Foreground="#7F8C8D"
                                                               Margin="0,0,0,4"
                                                               FontFamily="Segoe UI"/>

                                                    <ComboBox Grid.Row="1" Grid.Column="0"
                                                              ItemsSource="{Binding DataContext.RawMaterialOptions,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              DisplayMemberPath="DisplayText"
                                                              SelectedItem="{Binding SelectedMaterial}"
                                                              Height="34"
                                                              Margin="0,0,8,0"
                                                              FontFamily="Segoe UI"
                                                              FontSize="12"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1"
                                                             Text="{Binding Quantity,
                                                                 UpdateSourceTrigger=PropertyChanged}"
                                                             Height="34"
                                                             Margin="0,0,8,0"
                                                             VerticalContentAlignment="Center"
                                                             HorizontalContentAlignment="Center"
                                                             FontFamily="Segoe UI"/>
                                                    <TextBox Grid.Row="1" Grid.Column="2"
                                                             Text="{Binding UnitPrice,
                                                                 UpdateSourceTrigger=PropertyChanged}"
                                                             Height="34"
                                                             Margin="0,0,8,0"
                                                             VerticalContentAlignment="Center"
                                                             HorizontalContentAlignment="Center"
                                                             FontFamily="Segoe UI"/>
                                                    <Button Grid.Row="0" Grid.RowSpan="2"
                                                            Grid.Column="3"
                                                            Content="✕"
                                                            Width="32" Height="32"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemovePurchaseLineCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="#FDEDEC"
                                                            Foreground="#C0392B"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            ToolTip="حذف السطر"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Content="➕ سطر"
                                        Command="{Binding AddPurchaseLineCommand}"
                                        Height="32" HorizontalAlignment="Right"
                                        Margin="0,0,0,10"
                                        Padding="12,0"
                                        Background="{StaticResource ErpBrushPageBg}"
                                        BorderBrush="{StaticResource ErpBrushBorderInput}"
                                        BorderThickness="1"
                                        FontFamily="Segoe UI"
                                        Cursor="Hand"/>

                                <TextBlock Text="ملاحظات"
                                           FontSize="11"
                                           Foreground="{StaticResource ErpBrushTextSecondary}"/>
                                <TextBox Text="{Binding PurchaseNotes,
                                    UpdateSourceTrigger=PropertyChanged}"
                                         Height="50" TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Margin="0,4,0,12"
                                         Padding="8"
                                         FontFamily="Segoe UI"/>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Left">
                                    <Button Content="💾 حفظ الفاتورة"
                                            Command="{Binding SavePurchaseInvoiceCommand}"
                                            Height="38" Padding="16,0"
                                            Margin="0,0,8,0"
                                            Background="#27AE60"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            FontFamily="Segoe UI"
                                            Cursor="Hand"/>
                                    <Button Content="إلغاء"
                                            Command="{Binding CancelPurchaseInvoiceCommand}"
                                            Height="38" Padding="14,0"
                                            Background="{StaticResource ErpBrushPageBg}"
                                            Foreground="{StaticResource ErpBrushTextSecondary}"
                                            BorderBrush="{StaticResource ErpBrushBorderInput}"
                                            BorderThickness="1"
                                            FontFamily="Segoe UI"
                                            Cursor="Hand"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- ══ نموذج المورد ══ -->
            <Border Grid.Column="2"
                    Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="20" Margin="0,0,10,0"
                    Visibility="{Binding IsSupplierFormVisible,
                        Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding FormTitle}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource ErpBrushNavSidebar}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="الاسم *"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormName,
                                     UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" FontSize="12"
                                 FontFamily="Segoe UI"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="{StaticResource ErpBrushBorderInput}"
                                 BorderThickness="1.5"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="الشركة"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormCompany,
                                     UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" FontSize="12"
                                 FontFamily="Segoe UI"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="{StaticResource ErpBrushBorderInput}"
                                 BorderThickness="1.5"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="الهاتف"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormPhone,
                                     UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" FontSize="12"
                                 FontFamily="Segoe UI"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 BorderBrush="{StaticResource ErpBrushBorderInput}"
                                 BorderThickness="1.5"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="النوع"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#555"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,4"/>
                        <ComboBox
                            ItemsSource="{Binding SupplierTypes}"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Value"
                            SelectedValue="{Binding FormType}"
                            Height="36" FontFamily="Segoe UI"
                            FontSize="12" Margin="0,0,0,16"/>

                        <!-- رسائل -->
                        <Border Background="#FDEDEC" CornerRadius="8"
                                Padding="10,6" Margin="0,0,0,8"
                                Visibility="{Binding HasError,
                                    Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#E74C3C" FontSize="11"
                                       FontFamily="Segoe UI"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Background="#EAFAF1" CornerRadius="8"
                                Padding="10,6" Margin="0,0,0,8"
                                Visibility="{Binding SuccessMessage,
                                    Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding SuccessMessage}"
                                       Foreground="#27AE60" FontSize="11"
                                       FontFamily="Segoe UI"/>
                        </Border>

                        <Button Content="💾 حفظ"
                                Command="{Binding SaveSupplierCommand}"
                                Style="{StaticResource ErpPrimaryDarkButton}"
                                Margin="0,0,0,8"/>

                        <Button Content="إلغاء"
                                Command="{Binding CancelSupplierFormCommand}"
                                Style="{StaticResource ErpSecondaryButton}"
                                Height="34"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ══ نموذج الدفع ══ -->
            <Border Grid.Column="3"
                    Background="{StaticResource ErpBrushCard}" CornerRadius="12"
                    Padding="20"
                    Visibility="{Binding IsPayFormVisible,
                        Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.05"
                                      BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="💵 دفع للمورد"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#27AE60"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,14"/>

                    <!-- المورد -->
                    <Border Background="#EAFAF1" CornerRadius="8"
                            Padding="10,8" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock
                                Text="{Binding SelectedSupplier.FullName,
                                    FallbackValue='---'}"
                                FontSize="13" FontWeight="Bold"
                                Foreground="#27AE60"
                                FontFamily="Segoe UI"/>
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource ErpBrushTextSecondary}"
                                       FontFamily="Segoe UI">
                                <Run Text="الدين:"/>
                                <Run Text="{Binding SelectedSupplier.TotalDebt,
                                    FallbackValue='0',
                                    StringFormat='{}{0:N0} ر.ي'}"
                                     Foreground="#E74C3C"
                                     FontWeight="Bold"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- المبلغ -->
                    <TextBlock Text="المبلغ (ر.ي) *"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PayAmount,
                                 UpdateSourceTrigger=PropertyChanged}"
                             Height="38" FontSize="14"
                             FontFamily="Segoe UI"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="#27AE60"
                             BorderThickness="2"
                             Margin="0,0,0,12"/>

                    <!-- طريقة الدفع -->
                    <TextBlock Text="طريقة الدفع"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <ComboBox
                        ItemsSource="{Binding PaymentMethods}"
                        SelectedItem="{Binding PayMethod}"
                        Height="36" FontFamily="Segoe UI"
                        FontSize="12" Margin="0,0,0,12"/>

                    <!-- المرجع -->
                    <TextBlock Text="رقم العملية"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PayReference,
                                 UpdateSourceTrigger=PropertyChanged}"
                             Height="36" FontSize="12"
                             FontFamily="Segoe UI"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             BorderBrush="{StaticResource ErpBrushBorderInput}"
                             BorderThickness="1.5"
                             Margin="0,0,0,12"/>

                    <!-- ملاحظات -->
                    <TextBlock Text="ملاحظات"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#555"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBox Text="{Binding PayNotes,
                                 UpdateSourceTrigger=PropertyChanged}"
                             Height="60" TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalContentAlignment="Top"
                             FontSize="12" FontFamily="Segoe UI"
                             Padding="8"
                             BorderBrush="{StaticResource ErpBrushBorderInput}"
                             BorderThickness="1.5"
                             Margin="0,0,0,16"/>

                    <!-- رسائل -->
                    <Border Background="#FDEDEC" CornerRadius="8"
                            Padding="10,6" Margin="0,0,0,8"
                            Visibility="{Binding HasError,
                                Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#E74C3C" FontSize="11"
                                   FontFamily="Segoe UI"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Border Background="#EAFAF1" CornerRadius="8"
                            Padding="10,6" Margin="0,0,0,8"
                            Visibility="{Binding SuccessMessage,
                                Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding SuccessMessage}"
                                   Foreground="#27AE60" FontSize="11"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <Button Content="💾 تأكيد الدفع"
                            Command="{Binding SavePayCommand}"
                            Height="40" FontSize="13"
                            FontWeight="Bold"
                            FontFamily="Segoe UI"
                            Background="#27AE60"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,8"/>

                    <Button Content="إلغاء"
                            Command="{Binding CancelPayCommand}"
                            Height="34" FontSize="12"
                            FontFamily="Segoe UI"
                            Background="{StaticResource ErpBrushPageBg}"
                            Foreground="{StaticResource ErpBrushTextSecondary}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource ErpBrushBorderInput}"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
