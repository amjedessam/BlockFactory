<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ─── Semantic palette (aligned with existing screens) ─── -->
    <SolidColorBrush x:Key="ErpBrushPageBg" Color="#F0F2F5"/>
    <SolidColorBrush x:Key="ErpBrushCard" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErpBrushHeaderBar" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErpBrushBorder" Color="#E5E9EF"/>
    <SolidColorBrush x:Key="ErpBrushBorderInput" Color="#DDE1E7"/>
    <SolidColorBrush x:Key="ErpBrushTextPrimary" Color="#2C3E50"/>
    <SolidColorBrush x:Key="ErpBrushTextSecondary" Color="#7F8C8D"/>
    <SolidColorBrush x:Key="ErpBrushTextMuted" Color="#95A5A6"/>
    <SolidColorBrush x:Key="ErpBrushAccent" Color="#E67E22"/>
    <SolidColorBrush x:Key="ErpBrushSuccess" Color="#27AE60"/>
    <SolidColorBrush x:Key="ErpBrushDanger" Color="#E74C3C"/>
    <SolidColorBrush x:Key="ErpBrushNavSidebar" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="ErpBrushNavHover" Color="#2C4F7C"/>
    <SolidColorBrush x:Key="ErpBrushNavActive" Color="#E67E22"/>
    <SolidColorBrush x:Key="ErpBrushNavText" Color="#ECF0F1"/>
    <SolidColorBrush x:Key="ErpBrushGridLine" Color="#EDEFF2"/>
    <SolidColorBrush x:Key="ErpBrushRowAlt" Color="#FAFBFC"/>
    <SolidColorBrush x:Key="ErpBrushSoftFooter" Color="#F5F7FA"/>
    <SolidColorBrush x:Key="ErpBrushFieldLabel" Color="#555555"/>

    <!-- Legacy aliases (shell / views already use these names in places) -->
    <SolidColorBrush x:Key="SidebarBg" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="SidebarHover" Color="#2C4F7C"/>
    <SolidColorBrush x:Key="SidebarActive" Color="#E67E22"/>
    <SolidColorBrush x:Key="HeaderBg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ContentBg" Color="#F0F2F5"/>
    <SolidColorBrush x:Key="TextLight" Color="#ECF0F1"/>
    <SolidColorBrush x:Key="TextMuted" Color="#95A5A6"/>
    <SolidColorBrush x:Key="GroupTitle" Color="#7F8C8D"/>

    <!-- 8px rhythm -->
    <Thickness x:Key="ErpPaddingPage">24</Thickness>
    <Thickness x:Key="ErpPaddingCard">20,16</Thickness>
    <Thickness x:Key="ErpPaddingSection">0,0,0,16</Thickness>
    <sys:Double x:Key="ErpFontBody">13</sys:Double>
    <sys:Double x:Key="ErpFontTitle">18</sys:Double>
    <sys:Double x:Key="ErpFontStat">26</sys:Double>
    <sys:Double x:Key="ErpDataGridRowHeight">36</sys:Double>

    <!-- ─── Stat / KPI cards (shared by dashboard & reports-style tiles) ─── -->
    <Style x:Key="ErpStatCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ErpBrushCard}"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="{StaticResource ErpPaddingCard}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000"
                                  Opacity="0.06"
                                  BlurRadius="12"
                                  ShadowDepth="2"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ErpStatNumber" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource ErpFontStat}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="{StaticResource ErpBrushTextPrimary}"/>
    </Style>

    <Style x:Key="ErpStatTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource ErpBrushTextSecondary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <Style x:Key="ErpSectionHeading" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource ErpBrushTextPrimary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <!-- ─── Forms: consistent field height for fast data entry ─── -->
    <Style x:Key="ErpFormTextBox" TargetType="TextBox">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="FontSize" Value="{StaticResource ErpFontBody}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource ErpBrushCard}"/>
        <Setter Property="Foreground" Value="{StaticResource ErpBrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErpBrushBorderInput}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="ErpFormComboBox" TargetType="ComboBox">
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="FontSize" Value="{StaticResource ErpFontBody}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource ErpBrushCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErpBrushBorderInput}"/>
    </Style>

    <!-- Primary action: high contrast, keyboard-friendly focus -->
    <Style x:Key="ErpPrimaryButton" TargetType="Button">
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="MinWidth" Value="96"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="{StaticResource ErpFontBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource ErpBrushAccent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#FFFFFF"/>
                            <Setter TargetName="bd" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.92"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ErpSecondaryButton" TargetType="Button" BasedOn="{StaticResource ErpPrimaryButton}">
        <Setter Property="Foreground" Value="{StaticResource ErpBrushTextPrimary}"/>
        <Setter Property="Background" Value="{StaticResource ErpBrushCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErpBrushBorderInput}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd2"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd2" Property="BorderBrush"
                                    Value="{StaticResource ErpBrushAccent}"/>
                            <Setter TargetName="bd2" Property="BorderThickness" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd2" Property="Background" Value="#F8F9FA"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- زر أساسي بلون التنقل (حفظ طلب، إلخ.) -->
    <Style x:Key="ErpPrimaryDarkButton" TargetType="Button" BasedOn="{StaticResource ErpPrimaryButton}">
        <Setter Property="Background" Value="{StaticResource ErpBrushNavSidebar}"/>
        <Setter Property="MinHeight" Value="44"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- ─── Global DataGrid defaults: density + scanability ─── -->
    <Style TargetType="DataGrid">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="{StaticResource ErpFontBody}"/>
        <Setter Property="RowHeight" Value="{StaticResource ErpDataGridRowHeight}"/>
        <Setter Property="Background" Value="{StaticResource ErpBrushCard}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErpBrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ErpBrushGridLine}"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AlternationCount" Value="2"/>
        <Setter Property="RowBackground" Value="{StaticResource ErpBrushCard}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource ErpBrushRowAlt}"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="True"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F8F9FA"/>
        <Setter Property="Foreground" Value="{StaticResource ErpBrushTextSecondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Back-compat keys used across views -->
    <Style x:Key="StatCard" TargetType="Border" BasedOn="{StaticResource ErpStatCard}"/>
    <Style x:Key="StatNumber" TargetType="TextBlock" BasedOn="{StaticResource ErpStatNumber}"/>
    <Style x:Key="StatTitle" TargetType="TextBlock" BasedOn="{StaticResource ErpStatTitle}"/>

</ResourceDictionary>
